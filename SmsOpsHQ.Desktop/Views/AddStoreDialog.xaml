<Window x:Class="SmsOpsHQ.Desktop.Views.AddStoreDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add new store"
        Width="380" Height="Auto" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Bg}">

    <Border Padding="24" Margin="0">
        <StackPanel>
            <TextBlock Text="Store name" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8"/>
            <TextBox x:Name="StoreNameBox" Padding="12,10" FontSize="14"
                     VerticalContentAlignment="Center" Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="Cancel_Click"
                        Style="{StaticResource GhostButton}"
                        Padding="16,10" Margin="0,0,10,0"/>
                <Button Content="Add store" Click="AddStore_Click"
                        Style="{StaticResource PrimaryButton}"
                        Padding="16,10"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
