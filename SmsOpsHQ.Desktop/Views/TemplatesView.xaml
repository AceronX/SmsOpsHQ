<UserControl x:Class="SmsOpsHQ.Desktop.Views.TemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:TemplatesViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded">

    <Border Padding="28,24" Background="{StaticResource Bg}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Template list -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Button DockPanel.Dock="Right" Command="{Binding NewTemplateCommand}"
                            Style="{StaticResource PrimaryButton}" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="New"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="Message Templates" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Category filter pills -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="All" Command="{Binding SetCategoryCommand}" CommandParameter="All"
                            Padding="10,4" Margin="0,0,4,0" FontSize="11.5" FontWeight="Medium">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterAll}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryLight}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Primary}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="General" Command="{Binding SetCategoryCommand}" CommandParameter="General"
                            Padding="10,4" Margin="0,0,4,0" FontSize="11.5" FontWeight="Medium">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterGeneral}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryLight}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Primary}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Review" Command="{Binding SetCategoryCommand}" CommandParameter="Review"
                            Padding="10,4" FontSize="11.5" FontWeight="Medium">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterReview}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryLight}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Primary}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <Border Background="{StaticResource Surface}" CornerRadius="6"
                        BorderBrush="{StaticResource Border}" BorderThickness="1">
                    <ListBox ItemsSource="{Binding Templates}" SelectedItem="{Binding SelectedTemplate}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" BorderBrush="{StaticResource Divider}"
                                        BorderThickness="0,0,0,1" Cursor="Hand">
                                    <StackPanel>
                                        <DockPanel>
                                            <Border DockPanel.Dock="Right" Background="{StaticResource PrimaryLight}"
                                                    CornerRadius="4" Padding="5,1" VerticalAlignment="Center"
                                                    Margin="6,0,0,0">
                                                <TextBlock Text="{Binding Category}" FontSize="9.5"
                                                           Foreground="{StaticResource Primary}" FontWeight="SemiBold"/>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding Body}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   TextTrimming="CharacterEllipsis" MaxHeight="18"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- Editor panel -->
            <Border Grid.Column="1" Margin="12,0,0,0" Background="{StaticResource Surface}"
                    CornerRadius="8" Padding="20,18"
                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Edit Template" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                    <TextBlock Text="Template Name" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="Category" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                    <ComboBox SelectedValue="{Binding EditCategory}" SelectedValuePath="Content"
                              Margin="0,0,0,16" MaxWidth="180" HorizontalAlignment="Left">
                        <ComboBoxItem Content="General"/>
                        <ComboBoxItem Content="Review"/>
                    </ComboBox>

                    <TextBlock Text="Message Body" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding EditBody, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             MinHeight="120" Margin="0,0,0,8"/>

                    <!-- Placeholder hint for review templates -->
                    <Border Background="{StaticResource PrimaryLight}" CornerRadius="4" Padding="10,6" Margin="0,0,0,16">
                        <TextBlock FontSize="11" Foreground="{StaticResource Primary}" TextWrapping="Wrap">
                            <Run FontWeight="SemiBold" Text="Review template placeholders:"/>
                            <Run Text=" Use {link} for the review URL and {store} for the store name."/>
                        </TextBlock>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EditCategory}" Value="Review">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save" Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="18,8" Margin="0,0,8,0"/>
                        <Button Content="Delete" Command="{Binding DeleteCommand}"
                                Style="{StaticResource DangerButton}"
                                Padding="18,8" Margin="0,0,8,0"
                                Visibility="{Binding EditingTemplateId, Converter={StaticResource NullToCollapsed}}"/>
                        <Button Content="Cancel" Command="{Binding CancelEditCommand}"
                                Padding="18,8"/>
                    </StackPanel>

                    <Border Background="{StaticResource ErrorLight}" CornerRadius="5" Padding="10,7"
                            Margin="0,12,0,0"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
