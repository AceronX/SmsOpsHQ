<UserControl x:Class="SmsOpsHQ.Desktop.Views.ThreadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             xmlns:conv="clr-namespace:SmsOpsHQ.Desktop.Converters"
             d:DataContext="{d:DesignInstance vm:ThreadViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded">
    <UserControl.Resources>
        <conv:DirectionToAlignmentConverter x:Key="DirToAlign"/>
        <conv:DirectionToBubbleColorConverter x:Key="DirToBubbleColor"/>
        <conv:DirectionToTextColorConverter x:Key="DirToTextColor"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource Bg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: avatar + customer info -->
            <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,10"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="18"
                            Background="{StaticResource Primary}" VerticalAlignment="Center">
                        <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}"
                                   FontSize="16" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="{Binding CustomerName}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="{Binding CustomerPhone}" FontSize="11.5"
                                   Foreground="{StaticResource TextMuted}" Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Messages -->
            <ScrollViewer Grid.Row="1" x:Name="MessageScroller"
                          VerticalScrollBarVisibility="Auto"
                          Background="#F0F2F5" Padding="24,16">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <!-- Inbound messages: avatar + bubble (left-aligned) -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Top"
                                            HorizontalAlignment="Left" MaxWidth="420">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Direction}" Value="Outbound">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Direction}" Value="Note">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border Width="28" Height="28" CornerRadius="14"
                                            Background="#E5E7EB" VerticalAlignment="Bottom" Margin="0,0,8,0">
                                        <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="12" Foreground="#6B7280"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel>
                                        <Border Background="#FFFFFF"
                                                CornerRadius="4,16,16,16" Padding="14,10" MaxWidth="360">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.06"/>
                                            </Border.Effect>
                                            <StackPanel>
                                                <StackPanel Visibility="{Binding MediaJson, Converter={StaticResource StringToVisibility}}"
                                                            Margin="0,0,0,4">
                                                    <!-- Thumbnail with video play overlay -->
                                                    <Grid Cursor="Hand" HorizontalAlignment="Left"
                                                          MouseLeftButtonDown="MediaLink_Click"
                                                          Visibility="{Binding MediaThumbnail, Converter={StaticResource NullToCollapsed}}">
                                                        <Image Source="{Binding MediaThumbnail}"
                                                               MaxWidth="220" MaxHeight="220"
                                                               Stretch="Uniform"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        <Border Width="44" Height="44" CornerRadius="22"
                                                                Background="#88000000"
                                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                Visibility="{Binding IsVideoMedia, Converter={StaticResource BoolToVisibility}}">
                                                            <TextBlock Text="&#xE768;" FontFamily="{StaticResource IconFont}"
                                                                       FontSize="18" Foreground="White"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Margin="2,0,0,0"/>
                                                        </Border>
                                                    </Grid>
                                                    <!-- Non-image placeholder (no Shell thumbnail available) -->
                                                    <Border CornerRadius="8" Background="#1F2937" Padding="14,12" Cursor="Hand"
                                                            HorizontalAlignment="Left" MinWidth="160"
                                                            MouseLeftButtonDown="MediaLink_Click">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsNonImageMedia}" Value="True"/>
                                                                            <Condition Binding="{Binding MediaThumbnail}" Value="{x:Null}"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="36" Height="36" CornerRadius="18"
                                                                    Background="#374151" Margin="0,0,10,0">
                                                                <TextBlock Text="{Binding MediaIconGlyph}"
                                                                           FontFamily="{StaticResource IconFont}"
                                                                           FontSize="16" Foreground="White"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding MediaLabel}" FontSize="12"
                                                                           FontWeight="SemiBold" Foreground="#E5E7EB"/>
                                                                <TextBlock Text="Click to open" FontSize="10"
                                                                           Foreground="#6B7280" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                    <!-- Fallback link (image still loading or failed) -->
                                                    <TextBlock FontSize="11" Cursor="Hand"
                                                               TextDecorations="Underline"
                                                               Foreground="{StaticResource Primary}"
                                                               MouseLeftButtonDown="MediaLink_Click">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Setter Property="Text" Value="&#xE8B9;  View attachment"/>
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding MediaThumbnail}" Value="{x:Null}"/>
                                                                            <Condition Binding="{Binding IsNonImageMedia}" Value="False"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Body}" TextWrapping="Wrap" FontSize="13.5"
                                                           Foreground="#111827" LineHeight="20"/>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="{Binding CreatedAt}" FontSize="10" Margin="4,3,0,0"
                                                   Foreground="#9CA3AF"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Outbound messages: bubble + status (right-aligned) -->
                                <StackPanel HorizontalAlignment="Right" MaxWidth="420">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Direction}" Value="Outbound">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border Background="#2563EB"
                                            CornerRadius="16,4,16,16" Padding="14,10" MaxWidth="360">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <StackPanel Visibility="{Binding MediaJson, Converter={StaticResource StringToVisibility}}"
                                                        Margin="0,0,0,4">
                                                <!-- Thumbnail with video play overlay -->
                                                <Grid Cursor="Hand" HorizontalAlignment="Left"
                                                      MouseLeftButtonDown="MediaLink_Click"
                                                      Visibility="{Binding MediaThumbnail, Converter={StaticResource NullToCollapsed}}">
                                                    <Image Source="{Binding MediaThumbnail}"
                                                           MaxWidth="220" MaxHeight="220"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    <Border Width="44" Height="44" CornerRadius="22"
                                                            Background="#88000000"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                                            Visibility="{Binding IsVideoMedia, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="&#xE768;" FontFamily="{StaticResource IconFont}"
                                                                   FontSize="18" Foreground="White"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Margin="2,0,0,0"/>
                                                    </Border>
                                                </Grid>
                                                <!-- Non-image placeholder (no Shell thumbnail available) -->
                                                <Border CornerRadius="8" Background="#1D4ED8" Padding="14,12" Cursor="Hand"
                                                        HorizontalAlignment="Left" MinWidth="160"
                                                        MouseLeftButtonDown="MediaLink_Click">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsNonImageMedia}" Value="True"/>
                                                                        <Condition Binding="{Binding MediaThumbnail}" Value="{x:Null}"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="36" Height="36" CornerRadius="18"
                                                                Background="#2563EB" Margin="0,0,10,0">
                                                            <TextBlock Text="{Binding MediaIconGlyph}"
                                                                       FontFamily="{StaticResource IconFont}"
                                                                       FontSize="16" Foreground="White"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding MediaLabel}" FontSize="12"
                                                                       FontWeight="SemiBold" Foreground="White"/>
                                                            <TextBlock Text="Click to open" FontSize="10"
                                                                       Foreground="#93B4FD" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Fallback link (image still loading or failed) -->
                                                <TextBlock FontSize="11" Cursor="Hand"
                                                           TextDecorations="Underline"
                                                           Foreground="#BFDBFE"
                                                           MouseLeftButtonDown="MediaLink_Click">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="Text" Value="&#xE8B9;  View attachment"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding MediaThumbnail}" Value="{x:Null}"/>
                                                                        <Condition Binding="{Binding IsNonImageMedia}" Value="False"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Body}" TextWrapping="Wrap" FontSize="13.5"
                                                       Foreground="White" LineHeight="20"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3,4,0">
                                        <TextBlock Text="{Binding CreatedAt}" FontSize="10" Foreground="#9CA3AF"/>
                                        <TextBlock FontSize="10" Margin="6,0,0,0" Foreground="#9CA3AF">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#xE73E;"/>
                                                    <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Text" Value="&#xE783;"/>
                                                            <Setter Property="Foreground" Value="{StaticResource Error}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Queued">
                                                            <Setter Property="Text" Value="&#xE823;"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Note messages: centered -->
                                <StackPanel HorizontalAlignment="Center" MaxWidth="420">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Direction}" Value="Note">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border Background="#FEF3C7" CornerRadius="12" Padding="14,8">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="&#xE70B;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="10" Foreground="#92400E" Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="Internal Note" FontSize="10.5" FontWeight="SemiBold"
                                                           Foreground="#92400E"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Body}" TextWrapping="Wrap" FontSize="13"
                                                       Foreground="#78350F" LineHeight="18"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="{Binding CreatedAt}" FontSize="10" Margin="0,3,0,0"
                                               Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Compose bar -->
            <Border Grid.Row="2" Background="{StaticResource Surface}" Padding="16,12"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                <StackPanel>
                    <Border Background="{StaticResource Bg}" CornerRadius="8" Padding="12,10" Margin="0,0,0,10"
                            BorderBrush="{StaticResource Border}" BorderThickness="1"
                            Visibility="{Binding QuickTemplates.Count, Converter={StaticResource CountToVisibility}}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="Quick reply:" FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <ComboBox ItemsSource="{Binding QuickTemplates}"
                                      SelectedItem="{Binding SelectedQuickTemplate}"
                                      DisplayMemberPath="Name" FontSize="13" Padding="10,7"
                                      MinWidth="180"/>
                        </DockPanel>
                    </Border>
                    <Border Background="#F3F4F6" CornerRadius="22" Padding="4,3"
                            BorderBrush="{StaticResource Border}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding ComposeText, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="False" VerticalContentAlignment="Center"
                                     KeyDown="ComposeBox_KeyDown"
                                     Padding="16,9" FontSize="13.5">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Margin="{TemplateBinding Padding}"
                                                                  Background="Transparent"
                                                                  VerticalAlignment="Center"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <Button Grid.Column="1" Command="{Binding SendMessageCommand}"
                                    ToolTip="Send message (Enter)"
                                    Width="36" Height="36" Margin="2,0,2,0"
                                    VerticalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Width="36" Height="36" CornerRadius="18"
                                                            Background="Transparent"
                                                            SnapsToDevicePixels="True">
                                                        <TextBlock x:Name="Icon" Text="&#xE724;" FontFamily="{StaticResource IconFont}"
                                                                   FontSize="16" Foreground="{StaticResource Primary}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Primary}"/>
                                                            <Setter TargetName="Icon" Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryHover}"/>
                                                            <Setter TargetName="Icon" Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value="0.35"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Error -->
            <Border Grid.Row="3" Background="{StaticResource ErrorLight}" Padding="12,6"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
