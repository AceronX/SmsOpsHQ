<UserControl x:Class="SmsOpsHQ.Desktop.Views.RemindersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:RemindersViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded">

    <Grid Background="{StaticResource Bg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="20,16"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Right" Command="{Binding LoadRemindersCommand}"
                        Style="{StaticResource GhostButton}"
                        Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}"
                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="90"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Reminders" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Reminders.Count, StringFormat=' ({0})'}" FontSize="13"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                               Margin="4,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- List -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Reminders}"
                 SelectedItem="{Binding SelectedReminder}"
                 Background="{StaticResource Bg}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="16,12" BorderBrush="{StaticResource Divider}" BorderThickness="0,0,0,1"
                            Background="{StaticResource Surface}" Cursor="Hand">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Avatar -->
                            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                    Width="44" Height="44" CornerRadius="22"
                                    Background="{StaticResource Primary}" Margin="0,0,12,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding AvatarLetter}" FontSize="18" FontWeight="SemiBold"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- Row 1: CustomerName + TimeText -->
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CustomerName}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding TimeText}"
                                       FontSize="11" Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Center"/>

                            <!-- Row 2: Phone · #Ticket or Type -->
                            <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                       Text="{Binding SubtitleLine}" FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,2,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Loading overlay -->
        <Border Grid.Row="1" Background="#80F4F5F7"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Loading..." FontSize="13"
                           Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Error bar -->
        <Border Grid.Row="2" Background="{StaticResource ErrorLight}" Padding="16,8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
