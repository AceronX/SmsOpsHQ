<UserControl x:Class="SmsOpsHQ.Desktop.Views.CustomerPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:CustomerPanelViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" MinWidth="240">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Bg}">
        <StackPanel Margin="16,20,16,24">
            <!-- Customer name from XPD (or "Not in XPD" when not found). -->
            <TextBlock Text="{Binding CustomerName}" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"
                       Margin="0,0,0,4"/>

            <!-- Add Note to XPD: inline note input under the customer name. -->
            <StackPanel Margin="0,0,0,10"
                        Visibility="{Binding IsCustomerFound, Converter={StaticResource BoolToVisibility}}">
                <TextBox Text="{Binding NoteInput, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40" MaxHeight="70"
                         FontSize="12" Padding="8,6" Margin="0,0,0,4"
                         Tag="Write a note to XPD..."/>
                <Button Command="{Binding AppendNoteXpdCommand}" Padding="8,5" FontSize="11"
                        HorizontalAlignment="Left"
                        IsEnabled="{Binding IsSavingNote, Converter={StaticResource InvertBool}}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Setter Property="Background" Value="#F57F17"/>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="11"
                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Add Note to XPD" Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Warning banner shown only when customer has a warning. -->
            <Border Background="#FEF2F2" CornerRadius="6" Padding="10,6" Margin="0,0,0,10"
                    Visibility="{Binding WarningText, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding WarningText}" Foreground="{StaticResource Error}"
                           FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <!-- Address, phone, ID, and customer-since from XPD; actions: Call and Send SMS. -->
            <Border Background="{StaticResource Surface}" CornerRadius="8" Padding="12,10"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{Binding AddressLine}" FontSize="12"
                               Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding CityStateZip}" FontSize="12"
                               Foreground="{StaticResource TextPrimary}" Margin="0,1,0,0"
                               Visibility="{Binding CityStateZip, Converter={StaticResource StringToVisibility}}"/>
                    <TextBlock FontSize="12" Foreground="{StaticResource Primary}" Margin="0,4,0,0">
                        <Run Text="&#x260E; "/><Run Text="{Binding PhoneDisplay, Mode=OneWay}"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                Visibility="{Binding CustomerPhone, Converter={StaticResource StringToVisibility}}">
                        <Button Command="{Binding ClickToCallCommand}"
                                Style="{StaticResource GhostButton}" Padding="6,3" FontSize="11">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE717;" FontFamily="{StaticResource IconFont}" FontSize="12"
                                           Foreground="{StaticResource Primary}" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                <TextBlock Text="Call" Foreground="{StaticResource Primary}" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SendSmsCommand}"
                                Style="{StaticResource GhostButton}" Padding="6,3" FontSize="11" Margin="6,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE715;" FontFamily="{StaticResource IconFont}" FontSize="12"
                                           Foreground="{StaticResource Success}" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                <TextBlock Text="Send SMS" Foreground="{StaticResource Success}" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{Binding CallStatus}" FontSize="11"
                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="6,0,0,0"
                                   Visibility="{Binding CallStatus, Converter={StaticResource StringToVisibility}}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding IdInfo}" FontSize="10"
                               Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"
                               Visibility="{Binding IdInfo, Converter={StaticResource StringToVisibility}}"/>
                    <TextBlock Text="{Binding SinceDate}" FontSize="10"
                               Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"
                               Visibility="{Binding SinceDate, Converter={StaticResource StringToVisibility}}"/>
                </StackPanel>
            </Border>

            <!-- ═══════════  DECISION CARD — Hero  ═══════════ -->
            <Border CornerRadius="8" Padding="14,12"
                    Background="{Binding DecisionScoreBg, Converter={StaticResource HexToBrushConverter}}"
                    BorderBrush="{Binding DecisionBandColor, Converter={StaticResource HexToBrushConverter}}"
                    BorderThickness="1" Margin="0,0,0,10"
                    Visibility="{Binding HasDecisionCard, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="DECISION" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"/>

                    <!-- Score ring + band pill + primary reason -->
                    <DockPanel Margin="0,0,0,12">
                        <Grid DockPanel.Dock="Left" Width="54" Height="54" Margin="0,0,14,0">
                            <Border Width="54" Height="54" CornerRadius="27"
                                    Background="{Binding DecisionScoreColor, Converter={StaticResource HexToBrushConverter}}"/>
                            <Border Width="44" Height="44" CornerRadius="22" Background="White"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DecisionScore}" FontSize="19" FontWeight="Bold"
                                       Foreground="{Binding DecisionScoreColor, Converter={StaticResource HexToBrushConverter}}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <Border Background="{Binding DecisionBandColor, Converter={StaticResource HexToBrushConverter}}"
                                    CornerRadius="4" Padding="10,3" HorizontalAlignment="Left" Margin="0,0,0,5">
                                <TextBlock Text="{Binding DecisionBand}" Foreground="White"
                                           FontSize="11" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="{Binding DecisionPrimaryReason}" FontSize="11"
                                       Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Required action callout -->
                    <Border Background="#EFF6FF" CornerRadius="6" Padding="10,8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="&#xE7BA;" FontFamily="{StaticResource IconFont}"
                                       FontSize="14" Foreground="#2563EB" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding DecisionAction}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#1E40AF" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ═══════════  HISTORY — Stat Tiles  ═══════════ -->
            <Border Background="{StaticResource Surface}" CornerRadius="8" Padding="14,12"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="0,0,0,10"
                    Visibility="{Binding HasDecisionCard, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="HISTORY" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>

                    <!-- Row 1: Active / Overdue / All-Time -->
                    <UniformGrid Columns="3" Margin="0,0,0,4">
                        <Border Background="#F8FAFC" CornerRadius="6" Padding="0,7" Margin="0,0,3,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DecisionActiveDisplay}" FontSize="17" FontWeight="Bold"
                                           HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Active" FontSize="9" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FEF2F2" CornerRadius="6" Padding="0,7" Margin="2,0,2,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DecisionOverdueDisplay}" FontSize="17" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding DecisionOverdueColor, Converter={StaticResource HexToBrushConverter}}"/>
                                <TextBlock Text="Overdue" FontSize="9" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F8FAFC" CornerRadius="6" Padding="0,7" Margin="3,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DecisionAllTimeDisplay}" FontSize="17" FontWeight="Bold"
                                           HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="All-Time" FontSize="9" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Row 2: CPU / PFX / Ever Late -->
                    <UniformGrid Columns="3" Margin="0,0,0,8">
                        <Border Background="#F8FAFC" CornerRadius="6" Padding="0,7" Margin="0,0,3,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DecisionCpuDisplay}" FontSize="17" FontWeight="Bold"
                                           HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="CPU" FontSize="9" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FEF2F2" CornerRadius="6" Padding="0,7" Margin="2,0,2,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DecisionPfxDisplay}" FontSize="17" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding DecisionPfxColor, Converter={StaticResource HexToBrushConverter}}"/>
                                <TextBlock Text="PFX" FontSize="9" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FFFBEB" CornerRadius="6" Padding="0,7" Margin="3,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DecisionEverLateDisplay}" FontSize="17" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding DecisionEverLateColor, Converter={StaticResource HexToBrushConverter}}"/>
                                <TextBlock Text="Ever Late" FontSize="9" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Divider -->
                    <Border Height="1" Background="{StaticResource Border}" Margin="0,0,0,8"/>

                    <!-- Avg Days Late + Late Rate as labeled rows -->
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock DockPanel.Dock="Right" Text="{Binding DecisionAvgDaysLateDisplay}" FontSize="13" FontWeight="Bold"
                                   Foreground="{Binding DecisionAvgDaysLateColor, Converter={StaticResource HexToBrushConverter}}"/>
                        <TextBlock Text="Avg Days Late" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                    </DockPanel>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding DecisionLateRateDisplay}" FontSize="13" FontWeight="Bold"
                                   Foreground="{Binding DecisionLateRateColor, Converter={StaticResource HexToBrushConverter}}"/>
                        <TextBlock Text="Late Payment Rate" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- ═══════════  PROFILE & REVIEW  ═══════════ -->
            <Border Background="{StaticResource Surface}" CornerRadius="8" Padding="14,12"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="0,0,0,10"
                    Visibility="{Binding HasDecisionCard, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="PROFILE CHECKS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>

                    <!-- Profile check indicators with colored dot + label -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="16" Height="16" CornerRadius="8" Margin="0,0,6,0"
                                Background="{Binding IdStatusColor, Converter={StaticResource HexToBrushConverter}}">
                            <TextBlock Text="&#x2713;" Foreground="White" FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding IdStatus}" FontSize="11" VerticalAlignment="Center"
                                   Foreground="{Binding IdStatusColor, Converter={StaticResource HexToBrushConverter}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="16" Height="16" CornerRadius="8" Margin="0,0,6,0"
                                Background="{Binding AddressStatusColor, Converter={StaticResource HexToBrushConverter}}">
                            <TextBlock Text="&#x2713;" Foreground="White" FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding AddressStatus}" FontSize="11" VerticalAlignment="Center"
                                   Foreground="{Binding AddressStatusColor, Converter={StaticResource HexToBrushConverter}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="16" Height="16" CornerRadius="8" Margin="0,0,6,0"
                                Background="{Binding ContactStatusColor, Converter={StaticResource HexToBrushConverter}}">
                            <TextBlock Text="&#x2713;" Foreground="White" FontSize="9" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding ContactStatus}" FontSize="11" VerticalAlignment="Center"
                                   Foreground="{Binding ContactStatusColor, Converter={StaticResource HexToBrushConverter}}"/>
                    </StackPanel>

                    <!-- Review reason tag pills -->
                    <TextBlock Text="REVIEW FLAGS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"
                               Visibility="{Binding HasDecisionReviewReasons, Converter={StaticResource BoolToVisibility}}"/>
                    <ItemsControl ItemsSource="{Binding DecisionReviewReasonsList}"
                                  Visibility="{Binding HasDecisionReviewReasons, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFF7ED" CornerRadius="10" Padding="8,3"
                                        Margin="0,0,4,4" BorderBrush="#FDBA74" BorderThickness="1">
                                    <TextBlock Text="{Binding}" FontSize="10" FontWeight="SemiBold" Foreground="#C2410C"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Active, late, and all-time ticket counts; border highlights yellow for first-time customers. -->
            <Border Background="{StaticResource Surface}" CornerRadius="8" Padding="12,10"
                    BorderBrush="{Binding StatsBorderColor, Converter={StaticResource HexToBrushConverter}}"
                    BorderThickness="1" Margin="0,0,0,10">
                <StackPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock DockPanel.Dock="Right" Text="{Binding ActiveCount}" FontSize="13"
                                   FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Active Tickets" FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock DockPanel.Dock="Right" Text="{Binding LateCount}" FontSize="13"
                                   FontWeight="Bold" Foreground="{StaticResource Error}"/>
                        <TextBlock Text="Late Tickets" FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </DockPanel>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding AllTimeCount}" FontSize="13"
                                   FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="All-Time Tickets" FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Risk level and dynamic quality metrics from configurable query. -->
            <Border Background="{StaticResource Surface}" CornerRadius="8" Padding="12,10"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="CUSTOMER QUALITY" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                    <Border Background="{Binding RiskColor, Converter={StaticResource HexToBrushConverter}}"
                            CornerRadius="6" Padding="10,5" HorizontalAlignment="Left" Margin="0,0,0,8">
                        <TextBlock Text="{Binding RiskLevel}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                    </Border>
                    <!-- Dynamic quality metrics from configurable SQL query -->
                    <ItemsControl ItemsSource="{Binding QualityMetrics}"
                                  Visibility="{Binding HasQualityMetrics, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="13" Margin="0,0,0,4"
                                           Foreground="{Binding Color, Converter={StaticResource HexToBrushConverter}}">
                                    <Run Text="&#x2022; "/><Run Text="{Binding Label, Mode=OneWay}"/>
                                    <Run Text=": "/><Run Text="{Binding Value, Mode=OneWay}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Late rate, late/on-time counts, PFX sample, and worst late ticket; hidden when no payment history. -->
            <Border Background="{StaticResource Surface}" CornerRadius="8" Padding="12,10"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="0,0,0,10"
                    Visibility="{Binding HasPaymentHistory, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="PAYMENT HISTORY" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding LateRateDisplay}" FontSize="14" FontWeight="Bold"
                               Foreground="{Binding LateRateColor, Converter={StaticResource HexToBrushConverter}}"
                               Margin="0,0,0,6"/>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4">
                        <Run Text="&#x2022; "/><Run Text="{Binding PaymentStatsDisplay, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock FontSize="13" TextWrapping="Wrap" Margin="0,0,0,4"
                               Foreground="{Binding PfxHistoryColor, Converter={StaticResource HexToBrushConverter}}">
                        <Run Text="&#x2022; "/><Run Text="{Binding PfxHistoryDisplay, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock FontSize="13" TextWrapping="Wrap"
                               Foreground="{Binding WorstLateColor, Converter={StaticResource HexToBrushConverter}}">
                        <Run Text="&#x2022; "/><Run Text="{Binding WorstLateDisplay, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Customer, ticket, and item notes from XPD. -->
            <Border Background="#FFFDE7" CornerRadius="8" Padding="14,12"
                    BorderBrush="#FFF59D" BorderThickness="1" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="CUSTOMER NOTES (XPD)" FontSize="10" FontWeight="SemiBold"
                               Foreground="#F57F17" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CustomerNotes}" FontSize="12" Foreground="#5D4037"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <TextBlock Text="TICKET NOTES (XPD)" FontSize="10" FontWeight="SemiBold"
                               Foreground="#F57F17" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding TicketNotes}" FontSize="12" Foreground="#5D4037"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <TextBlock Text="ITEM NOTES (XPD)" FontSize="10" FontWeight="SemiBold"
                               Foreground="#F57F17" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding ItemNotes}" FontSize="12" Foreground="#5D4037"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Active tickets: simplified card with IssueDate, DueDate, Amount. -->
            <TextBlock Text="ACTIVE TICKETS" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"
                       Visibility="{Binding HasActiveTickets, Converter={StaticResource BoolToVisibility}}"/>
            <ItemsControl ItemsSource="{Binding ActiveTickets}"
                          Visibility="{Binding HasActiveTickets, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="6" Padding="10,8" Margin="0,0,0,6"
                                Background="{StaticResource Surface}"
                                BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}">
                                        <Run Text="Issue: "/><Run Text="{Binding IssueDate, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0">
                                        <Run Text="Due: "/><Run Text="{Binding DueDate, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Grid.Column="1" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center">
                                    <Run Text="$"/><Run Text="{Binding Amount, StringFormat='{}{0:N2}', Mode=OneWay}"/>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Shown when load or save fails. -->
            <Border Background="{StaticResource ErrorLight}" CornerRadius="4" Padding="10,6"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
