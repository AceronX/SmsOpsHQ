<UserControl x:Class="SmsOpsHQ.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Border Padding="28,24" Background="{StaticResource Bg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Settings" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

            <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}">

                <!-- Database -->
                <TabItem Header="Database">
                    <Border Padding="24,20" Background="{StaticResource Bg}">
                        <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                            <TextBlock Text="Database Connection" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,14"/>
                            <Button Content="Test Connection" Command="{Binding TestDatabaseCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Left" Margin="0,0,0,14"/>
                            <Border Background="{StaticResource Surface}" CornerRadius="6"
                                    Padding="14,12" BorderBrush="{StaticResource Border}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding DatabaseStatus}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding DatabaseDetails}" FontSize="12"
                                               Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Phone Numbers -->
                <TabItem Header="Phone Numbers">
                    <Border Padding="24,20" Background="{StaticResource Bg}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,14">
                                <Button DockPanel.Dock="Right" Content="Reload"
                                        Command="{Binding LoadPhoneNumbersCommand}"
                                        Padding="12,6"/>
                                <TextBlock Text="Twilio Phone Numbers" FontSize="15" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            </DockPanel>

                            <DataGrid ItemsSource="{Binding PhoneNumbers}" AutoGenerateColumns="False"
                                      IsReadOnly="True" Margin="0,0,0,14">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="*"/>
                                    <DataGridTextColumn Header="SID" Binding="{Binding Sid}" Width="*"/>
                                    <DataGridCheckBoxColumn Header="Default" Binding="{Binding IsDefault}" Width="70"/>
                                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <DockPanel MaxWidth="500" HorizontalAlignment="Left">
                                <Button DockPanel.Dock="Right" Content="Add"
                                        Command="{Binding AddPhoneNumberCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="14,7" Margin="8,0,0,0"/>
                                <TextBox Text="{Binding NewPhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalContentAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Twilio -->
                <TabItem Header="Twilio">
                    <Border Padding="24,20" Background="{StaticResource Bg}">
                        <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                            <TextBlock Text="Twilio Configuration" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,14"/>
                            <TextBlock Text="Account SID" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding TwilioSid, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,14"/>
                            <TextBlock Text="Auth Token" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                            <PasswordBox Margin="0,0,0,16"/>
                            <Button Content="Save" Command="{Binding SaveTwilioConfigCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Reminders -->
                <TabItem Header="Reminders">
                    <Border Padding="24,20" Background="{StaticResource Bg}">
                        <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                            <DockPanel Margin="0,0,0,14">
                                <Button DockPanel.Dock="Right" Content="Refresh"
                                        Command="{Binding LoadSchedulerStatusCommand}"
                                        Padding="12,6"/>
                                <TextBlock Text="Reminder Scheduler" FontSize="15" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            </DockPanel>

                            <Border Background="{StaticResource Surface}" CornerRadius="6"
                                    Padding="16,14" Margin="0,0,0,16"
                                    BorderBrush="{StaticResource Border}" BorderThickness="1">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,6">
                                        <TextBlock Text="Status" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMuted}" Width="80"/>
                                        <TextBlock Text="{Binding SchedulerRunning}" FontSize="13"
                                                   FontWeight="Medium" Foreground="{StaticResource TextPrimary}"/>
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,6">
                                        <TextBlock Text="Next Run" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMuted}" Width="80"/>
                                        <TextBlock Text="{Binding SchedulerNextRun}" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </DockPanel>
                                    <DockPanel>
                                        <TextBlock Text="Daily" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMuted}" Width="80"/>
                                        <TextBlock FontSize="13" Foreground="{StaticResource TextPrimary}">
                                            <Run Text="{Binding DailySent, Mode=OneWay}"/>
                                            <Run Text=" / "/>
                                            <Run Text="{Binding DailyLimit, Mode=OneWay}"/>
                                        </TextBlock>
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Start Scheduler" Command="{Binding StartSchedulerCommand}"
                                        Style="{StaticResource SuccessButton}"
                                        Padding="16,8" Margin="0,0,8,0"/>
                                <Button Content="Stop Scheduler" Command="{Binding StopSchedulerCommand}"
                                        Style="{StaticResource DangerButton}"
                                        Padding="16,8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- VoIP -->
                <TabItem Header="VoIP">
                    <Border Padding="24,20" Background="{StaticResource Bg}">
                        <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                            <TextBlock Text="XBlue VoIP Settings" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,14"/>
                            <CheckBox Content="Enable XBlue VoIP" IsChecked="{Binding XblueEnabled}"
                                      Margin="0,0,0,14"/>
                            <TextBlock Text="XBlue IP Address" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding XblueIp, UpdateSourceTrigger=PropertyChanged}"
                                     Width="280" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Presets -->
                <TabItem Header="Presets">
                    <Border Padding="24,20" Background="{StaticResource Bg}">
                        <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                            <TextBlock Text="Message Presets" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                            <TextBlock Text="Manage message templates from the Templates section in the sidebar."
                                       FontSize="13" Foreground="{StaticResource TextSecondary}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- General -->
                <TabItem Header="General">
                    <Border Padding="24,20" Background="{StaticResource Bg}">
                        <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                            <TextBlock Text="General Settings" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding AppVersion}" FontSize="13"
                                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,16"/>

                            <TextBlock Text="XPD Sync" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                            <Button Content="Trigger Full Sync" Command="{Binding TriggerSyncCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Left" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding SyncStatus}" FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
