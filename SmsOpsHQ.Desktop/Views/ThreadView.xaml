<UserControl x:Class="SmsOpsHQ.Desktop.Views.ThreadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             xmlns:conv="clr-namespace:SmsOpsHQ.Desktop.Converters"
             d:DataContext="{d:DesignInstance vm:ThreadViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded">
    <UserControl.Resources>
        <conv:DirectionToAlignmentConverter x:Key="DirToAlign"/>
        <conv:DirectionToBubbleColorConverter x:Key="DirToBubbleColor"/>
        <conv:DirectionToTextColorConverter x:Key="DirToTextColor"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource Bg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: Back + customer -->
            <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,14"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding GoBackCommand}"
                            Style="{StaticResource GhostButton}"
                            Padding="8,6" Margin="0,0,16,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72B;" FontFamily="{StaticResource IconFont}"
                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Back" FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource Primary}"/>
                        </StackPanel>
                    </Button>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CustomerName}" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="{Binding CustomerPhone}" FontSize="12"
                                   Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Messages -->
            <ScrollViewer Grid.Row="1" x:Name="MessageScroller"
                          VerticalScrollBarVisibility="Auto"
                          Background="#F0F2F5" Padding="28,20">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,8">
                                <Border HorizontalAlignment="{Binding Direction, Converter={StaticResource DirToAlign}}"
                                        Background="{Binding Direction, Converter={StaticResource DirToBubbleColor}}"
                                        CornerRadius="18" Padding="18,14" MaxWidth="420"
                                        BorderThickness="0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.06"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Body}" TextWrapping="Wrap" FontSize="14.5"
                                                   Foreground="{Binding Direction, Converter={StaticResource DirToTextColor}}"
                                                   LineHeight="24"/>
                                        <TextBlock Text="View attachment" FontSize="12"
                                                   Cursor="Hand" Margin="0,8,0,0"
                                                   TextDecorations="Underline"
                                                   Visibility="{Binding MediaJson, Converter={StaticResource StringToVisibility}}"
                                                   MouseLeftButtonDown="MediaLink_Click">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource Primary}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Direction}" Value="Outbound">
                                                            <Setter Property="Foreground" Value="#BFDBFE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding CreatedAt}" FontSize="11"
                                                       Foreground="{Binding Direction, Converter={StaticResource DirToTextColor}}"
                                                       Opacity="0.85"/>
                                            <TextBlock Text="{Binding Status}" FontSize="11"
                                                       Margin="10,0,0,0"
                                                       Foreground="{Binding Direction, Converter={StaticResource DirToTextColor}}"
                                                       Opacity="0.7"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Compose bar -->
            <Border Grid.Row="2" Background="{StaticResource Surface}" Padding="24,16"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,2,0,0">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12"
                               Visibility="{Binding QuickTemplates.Count, Converter={StaticResource CountToVisibility}}">
                        <TextBlock DockPanel.Dock="Left" Text="Quick reply:" FontSize="12"
                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <ComboBox ItemsSource="{Binding QuickTemplates}"
                                  SelectedItem="{Binding SelectedQuickTemplate}"
                                  DisplayMemberPath="Name" FontSize="12" Padding="10,6"
                                  MinWidth="160"/>
                    </DockPanel>
                    <Border Background="#F3F4F6" CornerRadius="24" Padding="4,4"
                            BorderBrush="{StaticResource Border}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding ComposeText, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="False" VerticalContentAlignment="Center"
                                     KeyDown="ComposeBox_KeyDown"
                                     Padding="20,12" FontSize="14" BorderThickness="0" Background="Transparent"/>
                            <Button Grid.Column="1" Command="{Binding SendMessageCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="20,10" Margin="6,0,0,0"
                                    VerticalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Send" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Text="&#xE724;" FontFamily="{StaticResource IconFont}"
                                               FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Error -->
            <Border Grid.Row="3" Background="{StaticResource ErrorLight}" Padding="16,7"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
