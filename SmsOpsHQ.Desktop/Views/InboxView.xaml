<UserControl x:Class="SmsOpsHQ.Desktop.Views.InboxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:InboxViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <!-- Filter pill button -->
        <Style x:Key="FilterPill" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource Bg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: title | search | actions -->
        <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,10"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="Inbox" FontSize="17" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    <Border Background="{StaticResource Primary}" CornerRadius="9" Padding="7,2" Margin="8,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding TotalThreads}" FontSize="10.5" FontWeight="Bold"
                                   Foreground="White"/>
                    </Border>
                </StackPanel>
                <Grid Grid.Column="1" Margin="16,0" HorizontalAlignment="Center" Width="260">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                             Padding="32,7,10,7" VerticalContentAlignment="Center"
                             FontSize="12.5" KeyDown="SearchBox_KeyDown">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{StaticResource Surface}"
                                                    BorderBrush="{StaticResource Border}"
                                                    BorderThickness="1" CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Border IsHitTestVisible="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                            Visibility="{Binding SearchText, Converter={StaticResource EmptyToVisible}}"
                            Padding="10,0,10,0">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="{StaticResource IconFont}"
                                       FontSize="13" Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="Search..."
                                       FontSize="12.5" Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding AskForReviewCommand}"
                            Style="{StaticResource PrimaryButton}" Padding="10,5" Margin="0,0,6,0"
                            FontSize="12" ToolTip="Ask for review">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE735;" FontFamily="{StaticResource IconFont}"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Ask for Review" FontWeight="SemiBold" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding NewCommand}"
                            Style="{StaticResource PrimaryButton}" Padding="10,5" Margin="0,0,6,0"
                            FontSize="12" ToolTip="New message">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="New" FontWeight="SemiBold" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding TrashCommand}"
                            Style="{StaticResource DangerButton}" Padding="10,5"
                            FontSize="12" ToolTip="Delete conversations">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Trash" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="1" Background="{StaticResource Surface}" Padding="16,6"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding TotalThreads, StringFormat='{}{0} conversations'}"
                           VerticalAlignment="Center"
                           FontSize="11" Foreground="{StaticResource TextMuted}"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="All" Command="{Binding SetFilterCommand}" CommandParameter="all">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterPill}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterAll}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryLight}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Primary}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Open" Command="{Binding SetFilterCommand}" CommandParameter="open">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterPill}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterOpen}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryLight}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Primary}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Unread" Command="{Binding SetFilterCommand}" CommandParameter="unread">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterPill}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterUnread}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryLight}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Primary}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Closed" Command="{Binding SetFilterCommand}" CommandParameter="closed">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FilterPill}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFilterClosed}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryLight}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Primary}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Three columns: list | thread content | customer panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <!-- Column 0: Conversation list -->
            <DockPanel Grid.Column="0">
                <!-- Selection toolbar (only in selection mode) -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource PrimaryLight}" Padding="8,6"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                        Visibility="{Binding IsSelectionMode, Converter={StaticResource BoolToVisibility}}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock VerticalAlignment="Center" FontSize="11.5"
                                       Foreground="{StaticResource Primary}" FontWeight="SemiBold" Margin="0,0,6,0">
                                <Run Text="{Binding CheckedCount, Mode=OneWay}"/>
                                <Run Text="selected"/>
                            </TextBlock>
                            <Button Content="Select All" Command="{Binding SelectAllCommand}"
                                    Style="{StaticResource GhostButton}" Padding="6,2" FontSize="11"
                                    Foreground="{StaticResource Primary}" Margin="0,0,2,0"/>
                            <Button Content="None" Command="{Binding DeselectAllCommand}"
                                    Style="{StaticResource GhostButton}" Padding="6,2" FontSize="11"
                                    Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding DeleteSelectedCommand}"
                                    Style="{StaticResource DangerButton}" Padding="6,3" FontSize="11"
                                    Margin="0,0,4,0" ToolTip="Delete selected or all">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}"
                                               FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBlock Text="Delete" FontSize="11" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            <Button Content="Cancel" Command="{Binding CancelSelectionCommand}"
                                    Style="{StaticResource GhostButton}" Padding="6,3" FontSize="11"
                                    Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <ListBox ItemsSource="{Binding Threads}"
                         SelectedItem="{Binding SelectedThread}"
                         Background="{StaticResource Bg}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,8" BorderBrush="{StaticResource Divider}" BorderThickness="0,0,0,1"
                                    Background="{StaticResource Surface}" Cursor="Hand">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Checkbox only visible in selection mode -->
                                    <CheckBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                              IsChecked="{Binding IsChecked}"
                                              VerticalAlignment="Center" Margin="0,0,6,0"
                                              Visibility="{Binding DataContext.IsSelectionMode,
                                                  RelativeSource={RelativeSource AncestorType=ListBox},
                                                  Converter={StaticResource BoolToVisibility}}"/>
                                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                            Width="36" Height="36" CornerRadius="18"
                                            Background="{StaticResource Primary}" Margin="0,0,10,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding AvatarLetter}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="White" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding DisplayName}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding LastMessageTime}"
                                               FontSize="10.5" Foreground="{StaticResource TextMuted}"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                                                Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding LastMessageBody}" FontSize="11.5"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="140"/>
                                        <Border Visibility="{Binding UnreadCount, Converter={StaticResource CountToVisibility}}"
                                                Background="{StaticResource Primary}" CornerRadius="7"
                                                Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding UnreadCount}" FontSize="9.5"
                                                       Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Column 1: Thread content or placeholder -->
            <Grid Grid.Column="1" Background="{StaticResource Bg}">
                <Border Visibility="{Binding CurrentThreadViewModel, Converter={StaticResource NullToVisible}}"
                        Background="{StaticResource Surface}" Padding="24">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8F1;" FontFamily="{StaticResource IconFont}"
                                   FontSize="28" Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Select a conversation"
                                   FontSize="13" Foreground="{StaticResource TextSecondary}"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
                <ContentPresenter Content="{Binding CurrentThreadViewModel}"
                                  Visibility="{Binding CurrentThreadViewModel, Converter={StaticResource NullToCollapsed}}"/>
            </Grid>

            <!-- Column 2: Customer panel or placeholder -->
            <Border Grid.Column="2" Background="{StaticResource Bg}" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0">
                <Grid>
                    <Border Visibility="{Binding CustomerPanel, Converter={StaticResource NullToVisible}}"
                            Background="{StaticResource Surface}" Padding="24">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}"
                                       FontSize="28" Foreground="{StaticResource TextMuted}"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Customer details"
                                       FontSize="13" Foreground="{StaticResource TextSecondary}"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ContentPresenter Content="{Binding CustomerPanel}"
                                      Visibility="{Binding CustomerPanel, Converter={StaticResource NullToCollapsed}}"/>
                </Grid>
            </Border>

            <!-- Loading overlay -->
            <Border Grid.ColumnSpan="3" Background="#80F4F5F7"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Loading..." FontSize="13"
                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Error bar -->
        <Border Grid.Row="3" Background="{StaticResource ErrorLight}" Padding="16,8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
