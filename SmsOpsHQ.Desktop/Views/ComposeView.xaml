<UserControl x:Class="SmsOpsHQ.Desktop.Views.ComposeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:ComposeViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded">

    <Border Background="{StaticResource Bg}" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,12"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <Border Width="32" Height="32" CornerRadius="8"
                            Background="{StaticResource Primary}" VerticalAlignment="Center">
                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}"
                                   FontSize="15" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="New Message" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Form content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="16,12,16,8">
                    <!-- To -->
                    <TextBlock Text="To" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondary}" Margin="2,0,0,5"/>
                    <TextBox Text="{Binding ToPhone, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Padding="10,8" Margin="0,0,0,12"
                             VerticalContentAlignment="Center"/>

                    <!-- Template -->
                    <TextBlock Text="Template (optional)" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondary}" Margin="2,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Templates}"
                              SelectedItem="{Binding SelectedTemplate}"
                              FontSize="12" Padding="10,7" Margin="0,0,0,12"
                              MinHeight="32">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="12"/>
                                    <TextBlock Text="{Binding Hotkey}" FontSize="10"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Message -->
                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="Message" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="2,0,0,0"/>
                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Text="{Binding SmsSegmentLabel}"
                                   FontSize="10" Foreground="{StaticResource TextMuted}"/>
                    </Grid>
                    <TextBox Text="{Binding Body, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="90" MaxHeight="160"
                             FontSize="13" Padding="10,8" Margin="0,0,0,8"/>

                    <!-- Error / Success -->
                    <Border Background="{StaticResource ErrorLight}" CornerRadius="6" Padding="10,8"
                            Margin="0,0,0,8"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE783;" FontFamily="{StaticResource IconFont}"
                                       FontSize="13" Foreground="{StaticResource Error}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}"
                                       FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource SuccessLight}" CornerRadius="6" Padding="10,8"
                            Margin="0,0,0,8"
                            Visibility="{Binding IsSent, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}"
                                       FontSize="13" Foreground="{StaticResource Success}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Sent!" Foreground="{StaticResource Success}"
                                       FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Actions -->
            <Border Grid.Row="2" Background="{StaticResource Surface}" Padding="16,10"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding CancelCommand}"
                            Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Left"
                            Padding="12,8" FontSize="12"
                            ToolTip="Close without sending">
                        <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                    </Button>
                    <Button Grid.Column="1" Command="{Binding SendCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                            Style="{StaticResource PrimaryButton}"
                            Padding="18,8" FontSize="13" FontWeight="SemiBold"
                            HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE724;" FontFamily="{StaticResource IconFont}"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding IsBusy, Converter={StaticResource BusyToButtonText}, ConverterParameter='Send|Sending...'}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
