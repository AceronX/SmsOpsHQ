<UserControl x:Class="SmsOpsHQ.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:LoginViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource Bg}">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Background="{StaticResource Surface}" CornerRadius="10"
                Padding="36,32" Width="360"
                BorderBrush="{StaticResource Border}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="24"
                                  ShadowDepth="4" Direction="270"/>
            </Border.Effect>
            <StackPanel>
                <!-- Logo -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Border Width="32" Height="32" CornerRadius="7"
                            Background="{StaticResource Primary}">
                        <TextBlock Text="&#xE715;" FontFamily="{StaticResource IconFont}"
                                   FontSize="16" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="SmsOps HQ" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <TextBlock Text="Sign in to your account" FontSize="13"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource TextMuted}" Margin="0,0,0,28"/>

                <!-- Username -->
                <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16"/>

                <!-- Password -->
                <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,8"
                             KeyDown="PasswordBox_KeyDown"/>

                <!-- Error -->
                <Border Background="{StaticResource ErrorLight}" CornerRadius="5"
                        Padding="10,7" Margin="0,0,0,8"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}"
                               FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <!-- Login button -->
                <Button Content="{Binding IsBusy, Converter={StaticResource BusyToButtonText}}"
                        Command="{Binding LoginCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                        Style="{StaticResource PrimaryButton}"
                        FontSize="14" Padding="0,11" Margin="0,8,0,0"
                        HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
