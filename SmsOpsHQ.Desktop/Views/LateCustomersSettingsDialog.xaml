<Window x:Class="SmsOpsHQ.Desktop.Views.LateCustomersSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Late Customers Query Settings"
        Width="700" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F4F5F7">

    <Border Padding="24" Margin="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="SQL Query Configuration" FontSize="18" FontWeight="Bold"
                           Foreground="#111827" Margin="0,0,0,8"/>
                <TextBlock FontSize="12" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,0,0,6">
                    <Run Text="Configure the SQL query used to retrieve late customers. You can change "/>
                    <Run Text="which rows" FontWeight="SemiBold"/>
                    <Run Text=" are returned (WHERE, JOIN, LIMIT, etc.)."/>
                </TextBlock>
                <TextBlock FontSize="11" Foreground="#9CA3AF" TextWrapping="Wrap">
                    <Run Text="Required column names (use AS if needed): Key, CustomerId, FirstName, LastName, ResPhone, BusPhone, CustomerNotes, TicketKey, TransNo, DueDate, CurrentBalance, Amount, TicketNotes, ForfeitCount, Items, ItemNotes, Category. StoreId is recommended; legacy queries infer it from Key."/>
                </TextBlock>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                <TextBox x:Name="QueryTextBox" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="Consolas"
                         FontSize="12"
                         Padding="12"
                         MinHeight="400"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Background="White"
                         BorderBrush="#E5E7EB"
                         BorderThickness="1"/>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Reset to Default" Click="Reset_Click"
                        Padding="16,10" Margin="0,0,10,0" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Cancel" Click="Cancel_Click"
                        Padding="16,10" Margin="0,0,10,0" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Save" Click="Save_Click"
                        Padding="16,10" Background="#2563EB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
