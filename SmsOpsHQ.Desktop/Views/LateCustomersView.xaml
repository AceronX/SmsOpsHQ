<UserControl x:Class="SmsOpsHQ.Desktop.Views.LateCustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:LateCustomersViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#B0BEC5"/>
            <Setter Property="BorderThickness" Value="0,0,2,2"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource Bg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="20,16"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Late Customers" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        <Border Background="{StaticResource Primary}" CornerRadius="10" Padding="8,2" Margin="8,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalCount}" FontSize="11" FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                        <Border Background="#1B5E20" CornerRadius="10" Padding="8,2" Margin="8,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalAmountDisplay}" FontSize="11" FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <Ellipse Width="10" Height="10" Fill="#d93025" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding CriticalCount}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#d93025" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Ellipse Width="10" Height="10" Fill="#f57c00" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding HighCount}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#f57c00" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Ellipse Width="10" Height="10" Fill="#f9ab00" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding MediumCount}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#f9ab00" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Ellipse Width="10" Height="10" Fill="#34a853" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding LowCount}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#34a853" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding LastSyncDisplay}" FontSize="11" Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Column="1" Margin="24,0" HorizontalAlignment="Center" Width="280">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                             Padding="36,10,12,10" VerticalContentAlignment="Center"
                             FontSize="13">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{StaticResource Surface}"
                                                    BorderBrush="{StaticResource Border}"
                                                    BorderThickness="1" CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Border IsHitTestVisible="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                            Visibility="{Binding SearchText, Converter={StaticResource EmptyToVisible}}"
                            Padding="12,0,12,0">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="20" Height="20" Margin="0,0,10,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="&#xE721;" FontFamily="{StaticResource IconFont}"
                                           FontSize="16" Foreground="{StaticResource TextMuted}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text="Search customers..."
                                       FontSize="13" Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource GhostButton}"
                            Padding="12,6" Margin="0,0,8,0"
                            ToolTip="Configure SQL Query &amp; Risk Settings">
                        <TextBlock Text="&#xE713;" FontFamily="{StaticResource IconFont}"
                                   FontSize="14" VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding LoadCommand}"
                            Style="{StaticResource GhostButton}" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="90"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock Text="Refresh"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" CornerRadius="6" BorderBrush="{StaticResource Border}"
                BorderThickness="1" Background="White" Margin="0,14,0,0">
            <DataGrid x:Name="LateGrid"
                      ItemsSource="{Binding Customers}" AutoGenerateColumns="False"
                      IsReadOnly="True" BorderThickness="0" GridLinesVisibility="None"
                      HeadersVisibility="Column" SelectionMode="Single"
                      Background="White" RowBackground="White" AlternatingRowBackground="#FAFAFA"
                      CanUserResizeColumns="True" CanUserSortColumns="True"
                      CanUserReorderColumns="True"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ColumnReordered="OnColumnReordered">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Days Late" Width="90" MinWidth="60"
                                            SortMemberPath="DaysLate" SortDirection="Descending">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#FFF5F5" CornerRadius="4" Padding="8,4" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding DaysLate, StringFormat='{}{0} Days'}"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="#d93025" HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Ticket" Binding="{Binding TicketNo}" Width="70" MinWidth="50">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="12,8"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Risk" Width="80" MinWidth="60"
                                            SortMemberPath="RiskScore">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="8,4" HorizontalAlignment="Center"
                                        Background="{Binding RiskColor, Converter={StaticResource HexToBrushConverter}, ConverterParameter=0.15}">
                                    <TextBlock Text="{Binding RiskBand}" FontSize="10" FontWeight="Bold"
                                               Foreground="{Binding RiskColor, Converter={StaticResource HexToBrushConverter}}"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Customer" Binding="{Binding FullName}" Width="140" MinWidth="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="12,8"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Amount" Binding="{Binding FormattedAmount}" Width="90" MinWidth="70"
                                        SortMemberPath="Amount">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="12,8"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Items" Binding="{Binding Items}" Width="200" MinWidth="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="MaxHeight" Value="60"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Setter Property="ToolTip" Value="{Binding Items}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="12,8"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Ticket Notes" Binding="{Binding TicketNotes}" Width="160" MinWidth="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Setter Property="ToolTip" Value="{Binding TicketNotes}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="12,8"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Item Notes" Binding="{Binding ItemNotes}" Width="160" MinWidth="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Setter Property="ToolTip" Value="{Binding ItemNotes}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="12,8"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Customer Notes" Binding="{Binding CustomerNotes}" Width="160" MinWidth="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Setter Property="ToolTip" Value="{Binding CustomerNotes}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="12,8"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Due Date" Binding="{Binding FormattedDueDate}" Width="95" MinWidth="75"
                                        SortMemberPath="DueDate">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="12,8"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="SMS" Width="50" MinWidth="44" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SendSmsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Send SMS"
                                        Style="{StaticResource GhostButton}"
                                        Padding="6,4" Margin="2,0">
                                    <TextBlock Text="&#xE8BD;" FontFamily="{StaticResource IconFont}" FontSize="14" Foreground="#2563EB"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Call" Width="50" MinWidth="44" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.CallCustomerCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="Call"
                                        Style="{StaticResource GhostButton}"
                                        Padding="6,4" Margin="2,0">
                                    <TextBlock Text="&#xE717;" FontFamily="{StaticResource IconFont}" FontSize="14" Foreground="#34a853"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Border>

        <Border Grid.Row="1" Background="#80F4F5F7"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Loading..." FontSize="14"
                           Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource ErrorLight}" Padding="16,10" Margin="0,14,0,0"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
