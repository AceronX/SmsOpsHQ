<UserControl x:Class="SmsOpsHQ.Desktop.Views.ReminderDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:ReminderDetailViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
            >

    <Grid Background="{StaticResource Bg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Reminder content: message + details (comfortable, easy to read) -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                          Background="{StaticResource Bg}" Padding="24,20">
                <StackPanel>
                    <!-- Section: Message -->
                    <TextBlock Text="Message" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>
                    <Border Background="{StaticResource Surface}" CornerRadius="8"
                            BorderBrush="{StaticResource Border}" BorderThickness="1"
                            Padding="20,18" Margin="0,0,0,24">
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="15"
                                   Foreground="{StaticResource TextPrimary}" LineHeight="24"
                                   FontWeight="Normal"/>
                    </Border>

                    <!-- Section: Details -->
                    <TextBlock Text="Details" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>
                    <Border Background="{StaticResource Surface}" CornerRadius="8"
                            BorderBrush="{StaticResource Border}" BorderThickness="1"
                            Padding="20,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Sent -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Sent"
                                       FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"
                                       Margin="0,0,0,14" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SentAtText}"
                                       FontSize="14" Foreground="{StaticResource TextPrimary}"
                                       Margin="0,0,0,14" VerticalAlignment="Center"/>
                            <!-- Ticket -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Ticket #"
                                       FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"
                                       Visibility="{Binding TransNo, Converter={StaticResource NullToCollapsed}}"
                                       Margin="0,0,0,14" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TransNo}"
                                       FontSize="14" Foreground="{StaticResource TextPrimary}"
                                       Visibility="{Binding TransNo, Converter={StaticResource NullToCollapsed}}"
                                       Margin="0,0,0,14" VerticalAlignment="Center"/>
                            <!-- Due -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Due date"
                                       FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"
                                       Visibility="{Binding DueDate, Converter={StaticResource StringToVisibility}}"
                                       Margin="0,0,0,14" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DueDate}"
                                       FontSize="14" Foreground="{StaticResource TextPrimary}"
                                       Visibility="{Binding DueDate, Converter={StaticResource StringToVisibility}}"
                                       Margin="0,0,0,14" VerticalAlignment="Center"/>
                            <!-- Type -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Type"
                                       FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"
                                       Visibility="{Binding ReminderType, Converter={StaticResource StringToVisibility}}"
                                       Margin="0,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ReminderType}"
                                       FontSize="14" Foreground="{StaticResource TextPrimary}"
                                       Visibility="{Binding ReminderType, Converter={StaticResource StringToVisibility}}"
                                       Margin="0,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Error -->
            <Border Grid.Row="1" Background="{StaticResource ErrorLight}" Padding="16,7"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
