<Window x:Class="SmsOpsHQ.Desktop.Views.MediaViewerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Media Viewer" Width="640" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="#111827">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Image Grid.Row="0" x:Name="MediaImage" Stretch="Uniform" Margin="20"/>

        <Border Grid.Row="1" Background="#1F2937" Padding="14,10">
            <DockPanel>
                <Button DockPanel.Dock="Right" Click="CloseButton_Click"
                        Padding="16,6" Background="Transparent" Foreground="#9CA3AF"
                        BorderBrush="#374151" BorderThickness="1" Cursor="Hand"
                        FontSize="13" Content="Close"/>
                <TextBlock x:Name="MediaInfo" Text="" FontSize="12"
                           Foreground="#9CA3AF" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
