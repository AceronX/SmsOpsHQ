<UserControl x:Class="SmsOpsHQ.Desktop.Views.ThreadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             xmlns:conv="clr-namespace:SmsOpsHQ.Desktop.Converters"
             d:DataContext="{d:DesignInstance vm:ThreadViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded">
    <UserControl.Resources>
        <conv:DirectionToAlignmentConverter x:Key="DirToAlign"/>
        <conv:DirectionToBubbleColorConverter x:Key="DirToBubbleColor"/>
        <conv:DirectionToTextColorConverter x:Key="DirToTextColor"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource Bg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Conversation -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,12"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <Button DockPanel.Dock="Left" Command="{Binding GoBackCommand}"
                            Style="{StaticResource GhostButton}"
                            Padding="8,6" Margin="0,0,12,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72B;" FontFamily="{StaticResource IconFont}"
                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Back" FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource Primary}"/>
                        </StackPanel>
                    </Button>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding CustomerName}" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="{Binding CustomerPhone}" FontSize="11.5"
                                   Foreground="{StaticResource TextMuted}" Margin="0,1,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Messages -->
            <ScrollViewer Grid.Row="1" x:Name="MessageScroller"
                          VerticalScrollBarVisibility="Auto"
                          Background="{StaticResource Bg}" Padding="20,12">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Border HorizontalAlignment="{Binding Direction, Converter={StaticResource DirToAlign}}"
                                        Background="{Binding Direction, Converter={StaticResource DirToBubbleColor}}"
                                        CornerRadius="14" Padding="14,9" MaxWidth="480">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Body}" TextWrapping="Wrap" FontSize="13.5"
                                                   Foreground="{Binding Direction, Converter={StaticResource DirToTextColor}}"
                                                   LineHeight="20"/>
                                        <!-- Media link -->
                                        <TextBlock Text="View attachment" FontSize="11"
                                                   Cursor="Hand" Margin="0,5,0,0"
                                                   TextDecorations="Underline"
                                                   Visibility="{Binding MediaJson, Converter={StaticResource StringToVisibility}}"
                                                   MouseLeftButtonDown="MediaLink_Click">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource Primary}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Direction}" Value="Outbound">
                                                            <Setter Property="Foreground" Value="#C7DBFF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Timestamp + status -->
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding CreatedAt}" FontSize="10"
                                                       Opacity="0.6">
                                                <TextBlock.Foreground>
                                                    <Binding Path="Direction" Converter="{StaticResource DirToTextColor}"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Status}" FontSize="10"
                                                       Opacity="0.6" Margin="8,0,0,0">
                                                <TextBlock.Foreground>
                                                    <Binding Path="Direction" Converter="{StaticResource DirToTextColor}"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Compose bar -->
            <Border Grid.Row="2" Background="{StaticResource Surface}" Padding="16,10"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                <StackPanel>
                    <!-- Quick reply selector -->
                    <DockPanel Margin="0,0,0,8"
                               Visibility="{Binding QuickTemplates.Count, Converter={StaticResource CountToVisibility}}">
                        <TextBlock DockPanel.Dock="Left" Text="Template:" FontSize="11.5"
                                   Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <ComboBox ItemsSource="{Binding QuickTemplates}"
                                  SelectedItem="{Binding SelectedQuickTemplate}"
                                  DisplayMemberPath="Name" FontSize="12" Padding="6,4"/>
                    </DockPanel>

                    <!-- Input + Send -->
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Command="{Binding SendMessageCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="14,8" Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Send" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="&#xE724;" FontFamily="{StaticResource IconFont}"
                                           FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <TextBox Text="{Binding ComposeText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="False" VerticalContentAlignment="Center"
                                 KeyDown="ComposeBox_KeyDown"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Error -->
            <Border Grid.Row="3" Background="{StaticResource ErrorLight}" Padding="16,7"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"/>
            </Border>
        </Grid>

        <!-- Right: Customer panel -->
        <Border Grid.Column="1" Width="320"
                BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0"
                Background="{StaticResource Bg}"
                Visibility="{Binding CustomerPanel, Converter={StaticResource NullToCollapsed}}">
            <ContentPresenter Content="{Binding CustomerPanel}"/>
        </Border>
    </Grid>
</UserControl>
