<UserControl x:Class="SmsOpsHQ.Desktop.Views.LateCustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:LateCustomersViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded">

    <Grid Background="{StaticResource Bg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="20,16"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Late Customers" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        <Border Background="{StaticResource Primary}" CornerRadius="10" Padding="8,2" Margin="8,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalCount}" FontSize="11" FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <Ellipse Width="10" Height="10" Fill="#d93025" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding CriticalCount}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#d93025" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Ellipse Width="10" Height="10" Fill="#f57c00" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding HighCount}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#f57c00" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Ellipse Width="10" Height="10" Fill="#f9ab00" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding MediumCount}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#f9ab00" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Ellipse Width="10" Height="10" Fill="#34a853" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding LowCount}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#34a853" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding LastSyncDisplay}" FontSize="11" Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Column="1" Margin="24,0" HorizontalAlignment="Center" Width="450">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="158"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                 Padding="36,10,12,10" VerticalContentAlignment="Center"
                                 FontSize="13">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="{StaticResource Surface}"
                                                        BorderBrush="{StaticResource Border}"
                                                        BorderThickness="1" CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <Border IsHitTestVisible="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                Visibility="{Binding SearchText, Converter={StaticResource EmptyToVisible}}"
                                Padding="12,0,12,0">
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="20" Height="20" Margin="0,0,10,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="&#xE721;" FontFamily="{StaticResource IconFont}"
                                               FontSize="16" Foreground="{StaticResource TextMuted}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Search customers..."
                                           FontSize="13" Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding CategoryFilters}"
                              SelectedItem="{Binding SelectedCategoryFilter, Mode=TwoWay}"
                              VerticalContentAlignment="Center" Padding="10,8"
                              ToolTip="Filter by pawn item category"
                              AutomationProperties.Name="Category filter"/>
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource GhostButton}"
                            Padding="12,6" Margin="0,0,8,0"
                            ToolTip="Configure SQL Query &amp; Risk Settings">
                        <TextBlock Text="&#xE713;" FontFamily="{StaticResource IconFont}"
                                   FontSize="14" VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding LoadCommand}"
                            Style="{StaticResource GhostButton}" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="90"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock Text="Refresh"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Card list | Customer panel -->
        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="Auto" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="6" BorderBrush="{StaticResource Border}"
                    BorderThickness="1" Background="White" Margin="0,0,8,0" ClipToBounds="True">
                <ListBox ItemsSource="{Binding Customers}"
                         SelectedItem="{Binding SelectedLateCustomer}"
                         BorderThickness="0" Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.CanContentScroll="True">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <!-- Full-width rows; bottom gap = two blank lines before next customer -->
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Top"/>
                            <Setter Property="Margin" Value="0,0,0,18"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBd" Background="Transparent" SnapsToDevicePixels="True"
                                                BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="4,2,8,0">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBd" Property="Background" Value="#E8F4FD"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:LateCustomerItem}">
                            <!-- 5 lines of text, then item margin gives "_" "_" gap to next -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- line 1 -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="#FFF5F5" CornerRadius="2" Padding="4,1" Margin="0,0,4,0">
                                            <TextBlock FontSize="9" FontWeight="Bold" Foreground="#d93025">
                                                <Run Text="{Binding DaysLate, Mode=OneWay}"/><Run Text="d"/>
                                            </TextBlock>
                                        </Border>
                                        <Border CornerRadius="6" Padding="4,1" Margin="0,0,4,0"
                                                Background="{Binding RiskColor, Converter={StaticResource HexToBrushConverter}, ConverterParameter=0.15}">
                                            <TextBlock Text="{Binding RiskBand}" FontSize="8" FontWeight="Bold"
                                                       Foreground="{Binding RiskColor, Converter={StaticResource HexToBrushConverter}}"/>
                                        </Border>
                                        <TextBlock Text="{Binding TicketNo, StringFormat='# {0}'}"
                                                   FontSize="9" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                        <ItemsControl ItemsSource="{Binding CategoryChips}" Margin="6,0,0,0"
                                                      VerticalAlignment="Center">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#EEF2FF" BorderBrush="#C7D2FE"
                                                            BorderThickness="1" CornerRadius="5"
                                                            Padding="4,1" Margin="0,0,3,0">
                                                        <TextBlock Text="{Binding}" FontSize="8" FontWeight="SemiBold"
                                                                   Foreground="#3730A3"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Command="{Binding DataContext.SendSmsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTipService.ShowOnDisabled="True"
                                                ToolTip="Compose SMS (same as customer panel — Twilio in Settings)"
                                                Style="{StaticResource GhostButton}" Padding="4,1" MinWidth="0">
                                            <TextBlock Text="&#xE8BD;" FontFamily="{StaticResource IconFont}" FontSize="11" Foreground="#2563EB"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.CallCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" ToolTip="Call"
                                                Style="{StaticResource GhostButton}" Padding="4,1" MinWidth="0">
                                            <TextBlock Text="&#xE717;" FontFamily="{StaticResource IconFont}" FontSize="11" Foreground="#34a853"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- line 2 -->
                                <Grid Grid.Row="1" Margin="0,1,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" MaxWidth="160"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Command="{Binding DataContext.OpenCustomerPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Padding="0,0,6,0" Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" ToolTip="Customer profile">
                                        <TextBlock Text="{Binding FullName}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Primary}" TextDecorations="Underline"
                                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                    </Button>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                               Text="{Binding AmountDuePhoneLine}"
                                               FontSize="9" Foreground="{StaticResource TextSecondary}"
                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                               TextAlignment="Right"
                                               ToolTip="{Binding AmountDuePhoneLine}"/>
                                </Grid>

                                <!-- line 3 -->
                                <TextBlock Grid.Row="2" Margin="0,1,0,0" Text="{Binding Items}"
                                           FontSize="9" Foreground="{StaticResource TextSecondary}"
                                           LineHeight="13" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                           ToolTip="{Binding Items}"/>

                                <!-- line 4 -->
                                <TextBlock Grid.Row="3" Margin="0,1,0,0" FontSize="8" Foreground="{StaticResource TextMuted}"
                                           LineHeight="12" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                           Visibility="{Binding TicketNotes, Converter={StaticResource StringToVisibility}}"
                                           ToolTip="{Binding TicketNotes}">
                                    <Run Text="T: "/><Run Text="{Binding TicketNotes, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- line 5 -->
                                <TextBlock Grid.Row="4" Margin="0,1,0,0" FontSize="8" Foreground="{StaticResource TextMuted}"
                                           LineHeight="12" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                           Visibility="{Binding CustomerNotes, Converter={StaticResource StringToVisibility}}"
                                           ToolTip="{Binding CustomerNotes}">
                                    <Run Text="C: "/><Run Text="{Binding CustomerNotes, Mode=OneWay}"/>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource Bg}" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0">
                <Grid MinWidth="272">
                    <Border Visibility="{Binding CustomerPanel, Converter={StaticResource NullToVisible}}"
                            Background="{StaticResource Surface}" Padding="20">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}"
                                       FontSize="26" Foreground="{StaticResource TextMuted}"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Customer details" FontSize="13" Foreground="{StaticResource TextSecondary}"
                                       TextAlignment="Center"/>
                            <TextBlock Text="Click a customer name" FontSize="11" Foreground="{StaticResource TextMuted}"
                                       TextAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <ContentPresenter Content="{Binding CustomerPanel}"
                                      Visibility="{Binding CustomerPanel, Converter={StaticResource NullToCollapsed}}"/>
                </Grid>
            </Border>

            <Border Grid.Column="0" Grid.ColumnSpan="2" Panel.ZIndex="10" Background="#80F4F5F7"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Loading..." FontSize="14"
                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource ErrorLight}" Padding="16,10" Margin="0,14,0,0"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
