<UserControl x:Class="SmsOpsHQ.Desktop.Views.CustomerPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:CustomerPanelViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" Width="320"
             Loaded="OnLoaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Bg}">
        <StackPanel Margin="20,20,20,24">

            <!-- Customer card -->
            <Border Background="{StaticResource Surface}" CornerRadius="8" Padding="16,14"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding CustomerName}" FontSize="17" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="{Binding CustomerPhone}" FontSize="13"
                                   Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                        <Button Command="{Binding ClickToCallCommand}"
                                Style="{StaticResource SuccessButton}"
                                Padding="10,4" Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE717;" FontFamily="{StaticResource IconFont}"
                                           FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Call"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="{Binding CallStatus}" FontSize="11"
                               Foreground="{StaticResource Primary}" Margin="0,0,0,4"
                               Visibility="{Binding CallStatus, Converter={StaticResource StringToVisibility}}"/>
                    <TextBlock Text="{Binding CustomerAddress}" FontSize="12"
                               Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                    <Border Background="{Binding RiskColor, Converter={StaticResource HexToBrushConverter}}" CornerRadius="6" Padding="10,5"
                            HorizontalAlignment="Left" Margin="0,10,0,0">
                        <TextBlock Text="{Binding RiskLevel}" Foreground="White" FontSize="12"
                                   FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Summary -->
            <TextBlock Text="SUMMARY" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
            <Border Background="{StaticResource Surface}" CornerRadius="8" Padding="16"
                    Margin="0,0,0,20"
                    BorderBrush="{StaticResource Border}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="ACTIVE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding ActiveCount}" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                        <TextBlock Text="LATE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding LateCount}" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource Error}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="PFX" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding PfxCount}" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource Warning}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                        <TextBlock Text="BALANCE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding TotalBalance, StringFormat='${0:N2}'}" FontSize="20"
                                   FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="LATE RATE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding LateRate, StringFormat='{}{0:N1}%'}" FontSize="14"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1">
                        <TextBlock Text="ALL TIME" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding AllTimeCount}" FontSize="14"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Active tickets -->
            <TextBlock Text="ACTIVE TICKETS" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding ActiveTickets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource Surface}" CornerRadius="6"
                                Padding="14,10" Margin="0,0,0,8"
                                BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" FontSize="11"
                                               Foreground="{StaticResource TextMuted}">
                                        <Run Text="$"/><Run Text="{Binding Balance, StringFormat='{}{0:N2}', Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}">
                                        <Run Text="#"/><Run Text="{Binding TransNo, Mode=OneWay}"/>
                                    </TextBlock>
                                </DockPanel>
                                <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0">
                                    <Run Text="Due: "/><Run Text="{Binding DueDate, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding Items}" FontSize="11"
                                           Foreground="{StaticResource TextSecondary}"
                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Notes -->
            <TextBlock Text="NOTES" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}" Margin="0,4,0,8"/>
            <TextBox Text="{Binding CustomerNotes, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="84"
                     FontSize="12" Padding="12,10" Margin="0,0,0,10"/>
            <Button Content="Save Notes" Command="{Binding SaveNotesCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Padding="14,8" FontSize="12" HorizontalAlignment="Left"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
