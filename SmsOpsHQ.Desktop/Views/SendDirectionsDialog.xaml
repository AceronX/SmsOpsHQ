<Window x:Class="SmsOpsHQ.Desktop.Views.SendDirectionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Send Directions"
        Width="420" Height="320"
        MinWidth="360" MinHeight="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Bg}">

    <Border Padding="24,20">
        <StackPanel>
            <TextBlock Text="Send Directions" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>

            <TextBlock Text="Sends a text with a Google Maps driving link to your store address."
                       FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,16"/>

            <TextBlock Text="Customer Phone Number" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
            <TextBox x:Name="PhoneBox" Padding="10,8" FontSize="13" Margin="0,0,0,12"/>

            <TextBlock Text="Destination" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
            <TextBlock x:Name="DestinationPreview" FontSize="12" TextWrapping="Wrap"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

            <Button x:Name="SendButton" Content="Send Directions" Click="SendButton_Click"
                    Style="{StaticResource PrimaryButton}" Padding="16,8" FontSize="13"
                    HorizontalAlignment="Left" Margin="0,0,0,12"/>

            <TextBlock x:Name="StatusText" FontSize="12" TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>

            <Border x:Name="ErrorBorder" Background="{StaticResource ErrorLight}" CornerRadius="5"
                    Padding="10,7" Margin="0,8,0,0" Visibility="Collapsed">
                <TextBlock x:Name="ErrorText" Foreground="{StaticResource Error}" FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
    </Border>
</Window>
