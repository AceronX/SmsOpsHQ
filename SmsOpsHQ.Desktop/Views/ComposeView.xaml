<UserControl x:Class="SmsOpsHQ.Desktop.Views.ComposeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:ComposeViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded">

    <Border Padding="28,24" Background="{StaticResource Bg}">
        <Grid MaxWidth="600" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" Text="New Message" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>

            <!-- To phone -->
            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                <TextBlock Text="Recipient Phone Number" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                <TextBox Text="{Binding ToPhone, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <!-- Template selector -->
            <StackPanel Grid.Row="2" Margin="0,0,0,16">
                <TextBlock Text="Quick Template (optional)" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding Templates}"
                          SelectedItem="{Binding SelectedTemplate}"
                          FontSize="13" Padding="8,6">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="Medium" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Hotkey}" FontSize="11"
                                           Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Message body -->
            <DockPanel Grid.Row="3" Margin="0,0,0,16">
                <TextBlock DockPanel.Dock="Top" Text="Message" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                <TextBox Text="{Binding Body, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="140"/>
            </DockPanel>

            <!-- Status messages -->
            <StackPanel Grid.Row="4" Margin="0,0,0,12">
                <Border Background="{StaticResource ErrorLight}" CornerRadius="5" Padding="12,8"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"/>
                </Border>
                <Border Background="{StaticResource SuccessLight}" CornerRadius="5" Padding="12,8"
                        Visibility="{Binding IsSent, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Message sent successfully." Foreground="{StaticResource Success}"
                               FontSize="12" FontWeight="Medium"/>
                </Border>
            </StackPanel>

            <!-- Send button -->
            <StackPanel Grid.Row="5" Orientation="Horizontal">
                <Button Content="Send Message" Command="{Binding SendCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                        Style="{StaticResource PrimaryButton}"
                        FontSize="14" Padding="24,10"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
