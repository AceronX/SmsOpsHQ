<Window x:Class="SmsOpsHQ.Desktop.Views.PhonePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose phone number"
        Width="340" Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F5F7">
    <Border Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="This customer has multiple phone numbers. Choose one to send SMS:"
                       TextWrapping="Wrap" Margin="0,0,0,12" Foreground="#111827" FontSize="13"/>
            <ListBox x:Name="PhoneList" Grid.Row="1" Margin="0,0,0,16"
                     SelectionMode="Single" FontSize="14"
                     BorderBrush="#E5E7EB" BorderThickness="1"
                     Background="White"/>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="Cancel_Click" Padding="16,8" Margin="0,0,8,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Send SMS" Click="Ok_Click" Padding="16,8"
                        Background="#2563EB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
