<Window x:Class="SmsOpsHQ.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SmsOps HQ"
        Height="760" Width="1160"
        MinHeight="620" MinWidth="940"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}">

    <Window.Resources>
        <!-- Sidebar nav button style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource SidebarText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="0" SnapsToDevicePixels="True">
                            <Grid>
                                <!-- Active indicator bar -->
                                <Border x:Name="ActiveBar" Width="3" HorizontalAlignment="Left"
                                        Background="Transparent" CornerRadius="0,2,2,0"/>
                                <ContentPresenter Margin="20,0,12,0"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SidebarHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ════════════════════════════════════════════════════════ -->
        <!--  SIDEBAR                                                -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <DockPanel>
                <!-- Bottom: user info + sign out -->
                <Border DockPanel.Dock="Bottom" Padding="16,12"
                        BorderBrush="#2C2F3A" BorderThickness="0,1,0,0">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Command="{Binding LogoutCommand}"
                                Style="{StaticResource GhostButton}"
                                Foreground="{StaticResource SidebarText}"
                                Padding="6,4" VerticalAlignment="Center"
                                ToolTip="Sign out">
                            <TextBlock Text="&#xE7E8;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                        </Button>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding AppState.CurrentUser.Username}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource SidebarTextActive}"
                                       TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <!-- Connection dot -->
                                <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,5,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource Error}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AppState.IsSignalRConnected}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource Success}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding AppState.CurrentUser.Role}"
                                           FontSize="11" Foreground="{StaticResource SidebarText}"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Top: logo + navigation -->
                <StackPanel>
                    <!-- App name -->
                    <StackPanel Orientation="Horizontal" Margin="20,20,16,24">
                        <Border Width="28" Height="28" CornerRadius="6"
                                Background="{StaticResource Primary}">
                            <TextBlock Text="&#xE715;" FontFamily="{StaticResource IconFont}"
                                       FontSize="14" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="SmsOps HQ" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource SidebarTextActive}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Compose button -->
                    <Border Margin="12,0,12,16">
                        <Button Command="{Binding NavigateCommand}" CommandParameter="Compose"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalContentAlignment="Center" Padding="0,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}"
                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Compose" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Nav section label -->
                    <TextBlock Text="NAVIGATION" FontSize="10" FontWeight="SemiBold"
                               Foreground="#4A4D57" Margin="20,0,0,6"/>

                    <!-- Inbox -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Inbox">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE715;" FontFamily="{StaticResource IconFont}"
                                       FontSize="14" VerticalAlignment="Center"
                                       Width="22"/>
                            <TextBlock Text="Inbox" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavItem}" Value="Inbox">
                                        <Setter Property="Background" Value="{StaticResource SidebarActive}"/>
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextActive}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Reminders -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Reminders">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE823;" FontFamily="{StaticResource IconFont}"
                                       FontSize="14" VerticalAlignment="Center"
                                       Width="22"/>
                            <TextBlock Text="Reminders" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavItem}" Value="Reminders">
                                        <Setter Property="Background" Value="{StaticResource SidebarActive}"/>
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextActive}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Late Customers -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Late">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE823;" FontFamily="{StaticResource IconFont}"
                                       FontSize="14" VerticalAlignment="Center"
                                       Width="22"/>
                            <TextBlock Text="Late Customers" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavItem}" Value="Late">
                                        <Setter Property="Background" Value="{StaticResource SidebarActive}"/>
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextActive}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- PFX Report -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="PFX">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7C3;" FontFamily="{StaticResource IconFont}"
                                       FontSize="14" VerticalAlignment="Center"
                                       Width="22"/>
                            <TextBlock Text="PFX Report" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavItem}" Value="PFX">
                                        <Setter Property="Background" Value="{StaticResource SidebarActive}"/>
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextActive}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Templates -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Templates">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8C1;" FontFamily="{StaticResource IconFont}"
                                       FontSize="14" VerticalAlignment="Center"
                                       Width="22"/>
                            <TextBlock Text="Templates" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavItem}" Value="Templates">
                                        <Setter Property="Background" Value="{StaticResource SidebarActive}"/>
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextActive}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Divider -->
                    <Border Height="1" Background="#2C2F3A" Margin="16,12"/>

                    <!-- Settings -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="Settings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="{StaticResource IconFont}"
                                       FontSize="14" VerticalAlignment="Center"
                                       Width="22"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNavItem}" Value="Settings">
                                        <Setter Property="Background" Value="{StaticResource SidebarActive}"/>
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextActive}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════ -->
        <!--  MAIN CONTENT                                             -->
        <!-- ════════════════════════════════════════════════════════ -->
        <ContentPresenter Grid.Column="1" Content="{Binding CurrentView}"/>
    </Grid>
</Window>
