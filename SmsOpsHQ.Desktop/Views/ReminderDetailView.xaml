<UserControl x:Class="SmsOpsHQ.Desktop.Views.ReminderDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:ReminderDetailViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded">

    <Grid Background="{StaticResource Bg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Back + reminder card -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with Back -->
            <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,12"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <Button DockPanel.Dock="Left" Command="{Binding GoBackCommand}"
                            Style="{StaticResource GhostButton}"
                            Padding="8,6" Margin="0,0,12,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72B;" FontFamily="{StaticResource IconFont}"
                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Back to Reminders" FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource Primary}"/>
                        </StackPanel>
                    </Button>
                </DockPanel>
            </Border>

            <!-- Reminder message card -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Background="{StaticResource Bg}" Padding="20,16">
                <Border Background="{StaticResource Surface}" CornerRadius="8"
                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                        Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="Reminder sent" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="14"
                                   Foreground="{StaticResource TextPrimary}" LineHeight="22"
                                   Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="{Binding SentAtText}" FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Visibility="{Binding TransNo, Converter={StaticResource NullToCollapsed}}">
                            <TextBlock Text="Ticket #: " FontSize="12"
                                       Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding TransNo}" FontSize="12"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                    Visibility="{Binding DueDate, Converter={StaticResource StringToVisibility}}">
                            <TextBlock Text="Due: " FontSize="12"
                                       Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding DueDate}" FontSize="12"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                    Visibility="{Binding ReminderType, Converter={StaticResource StringToVisibility}}">
                            <TextBlock Text="Type: " FontSize="12"
                                       Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding ReminderType}" FontSize="12"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Error -->
            <Border Grid.Row="2" Background="{StaticResource ErrorLight}" Padding="16,7"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"/>
            </Border>
        </Grid>

        <!-- Right: Customer context panel -->
        <Border Grid.Column="1" Width="320"
                BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0"
                Background="{StaticResource Bg}"
                Visibility="{Binding CustomerPanel, Converter={StaticResource NullToCollapsed}}">
            <ContentPresenter Content="{Binding CustomerPanel}"/>
        </Border>
    </Grid>
</UserControl>
