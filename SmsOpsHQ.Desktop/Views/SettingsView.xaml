<UserControl x:Class="SmsOpsHQ.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Border Padding="28,24" Background="{StaticResource Bg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Settings" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

            <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}">

                <!-- Credentials -->
                <TabItem Header="Credentials" Loaded="CredentialsTab_Loaded">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="280" MaxWidth="400"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*" MinWidth="280" MaxWidth="400"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Username card -->
                            <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource Surface}"
                                    CornerRadius="10" BorderBrush="{StaticResource Border}" BorderThickness="1"
                                    Padding="24,20" Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="0"/>
                                </Border.Effect>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="16" Foreground="{StaticResource Primary}"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="Username" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="Change your login username."
                                               FontSize="12" Foreground="{StaticResource TextMuted}"
                                               Margin="0,0,0,16"/>

                                    <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" FontSize="14" Margin="0,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Password card -->
                            <Border Grid.Row="0" Grid.Column="2" Background="{StaticResource Surface}"
                                    CornerRadius="10" BorderBrush="{StaticResource Border}" BorderThickness="1"
                                    Padding="24,20" Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="0"/>
                                </Border.Effect>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="&#xE72E;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="16" Foreground="{StaticResource Primary}"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="Password" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="Leave blank to keep your current password."
                                               FontSize="12" Foreground="{StaticResource TextMuted}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Min 8 characters, uppercase, lowercase, and a number."
                                               FontSize="11" Foreground="{StaticResource TextMuted}"
                                               Margin="0,0,0,16"/>

                                    <TextBlock Text="Current password" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                            BorderThickness="1" CornerRadius="6" Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <PasswordBox x:Name="CredentialOldPassword" Grid.Column="0"
                                                         Style="{StaticResource PasswordFieldPasswordBox}"
                                                         Padding="12,10,4,10" FontSize="14"
                                                         PasswordChanged="CredentialPassword_PasswordChanged"
                                                         Visibility="{Binding ShowOldPassword, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                                            <TextBox x:Name="CredentialOldPasswordTextBox" Grid.Column="0"
                                                     Style="{StaticResource PasswordFieldTextBox}"
                                                     Text="{Binding OldPassword, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="12,10,4,10" FontSize="14"
                                                     Visibility="{Binding ShowOldPassword, Converter={StaticResource BoolToVisibility}}"/>
                                            <Button Grid.Column="1" Click="ToggleCredentialOldPassword_Click"
                                                    Style="{StaticResource PasswordEyeButton}"
                                                    VerticalAlignment="Stretch" ToolTip="Show / hide password">
                                                <TextBlock x:Name="CredentialOldPasswordEyeIcon" Text="&#xE7B3;"
                                                           FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="New password" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                            BorderThickness="1" CornerRadius="6" Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <PasswordBox x:Name="CredentialNewPassword" Grid.Column="0"
                                                         Style="{StaticResource PasswordFieldPasswordBox}"
                                                         Padding="12,10,4,10" FontSize="14"
                                                         PasswordChanged="CredentialPassword_PasswordChanged"
                                                         Visibility="{Binding ShowNewPassword, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                                            <TextBox x:Name="CredentialNewPasswordTextBox" Grid.Column="0"
                                                     Style="{StaticResource PasswordFieldTextBox}"
                                                     Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="12,10,4,10" FontSize="14"
                                                     Visibility="{Binding ShowNewPassword, Converter={StaticResource BoolToVisibility}}"/>
                                            <Button Grid.Column="1" Click="ToggleCredentialNewPassword_Click"
                                                    Style="{StaticResource PasswordEyeButton}"
                                                    VerticalAlignment="Stretch" ToolTip="Show / hide password">
                                                <TextBlock x:Name="CredentialNewPasswordEyeIcon" Text="&#xE7B3;"
                                                           FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="Confirm new password" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                            BorderThickness="1" CornerRadius="6" Margin="0,0,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <PasswordBox x:Name="CredentialConfirmPassword" Grid.Column="0"
                                                         Style="{StaticResource PasswordFieldPasswordBox}"
                                                         Padding="12,10,4,10" FontSize="14"
                                                         PasswordChanged="CredentialPassword_PasswordChanged"
                                                         Visibility="{Binding ShowConfirmPassword, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                                            <TextBox x:Name="CredentialConfirmPasswordTextBox" Grid.Column="0"
                                                     Style="{StaticResource PasswordFieldTextBox}"
                                                     Text="{Binding ConfirmNewPassword, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="12,10,4,10" FontSize="14"
                                                     Visibility="{Binding ShowConfirmPassword, Converter={StaticResource BoolToVisibility}}"/>
                                            <Button Grid.Column="1" Click="ToggleCredentialConfirmPassword_Click"
                                                    Style="{StaticResource PasswordEyeButton}"
                                                    VerticalAlignment="Stretch" ToolTip="Show / hide password">
                                                <TextBlock x:Name="CredentialConfirmPasswordEyeIcon" Text="&#xE7B3;"
                                                           FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Alerts: full width -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,8">
                                <Border Background="{StaticResource ErrorLight}" CornerRadius="8" Padding="14,10"
                                        Margin="0,0,0,6"
                                        Visibility="{Binding CredentialErrorMessage, Converter={StaticResource StringToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE783;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="14" Foreground="{StaticResource Error}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding CredentialErrorMessage}" Foreground="{StaticResource Error}"
                                                   FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{StaticResource SuccessLight}" CornerRadius="8" Padding="14,10"
                                        Visibility="{Binding CredentialSuccessMessage, Converter={StaticResource StringToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="14" Foreground="{StaticResource Success}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding CredentialSuccessMessage}" Foreground="{StaticResource Success}"
                                                   FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Save button: full width -->
                            <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                    Command="{Binding SaveCredentialsCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                                    Padding="24,12" FontSize="14" FontWeight="SemiBold"
                                    HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}"
                                               FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Save changes" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- Database -->
                <TabItem Header="Database" Loaded="DatabaseTab_Loaded">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="300"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*" MinWidth="300"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Left: Connection card -->
                            <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource Surface}"
                                    CornerRadius="10" BorderBrush="{StaticResource Border}" BorderThickness="1"
                                    Padding="24,20" Margin="0,0,0,24">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="0"/>
                                </Border.Effect>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="&#xE7BE;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="16" Foreground="{StaticResource Primary}"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="Database connection" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="Verify the API can reach the SQLite database and pawn data tables."
                                               FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>
                                    <Button Command="{Binding TestDatabaseCommand}"
                                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                                            Style="{StaticResource PrimaryButton}"
                                            Padding="16,10" HorizontalAlignment="Left" Margin="0,0,0,14">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE72E;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Test DB Connection" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Border Background="{StaticResource Surface}" CornerRadius="6"
                                            Padding="14,12" BorderBrush="{StaticResource Border}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DatabaseStatus}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding DatabaseDetails}" FontSize="12"
                                                       Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource SuccessLight}" CornerRadius="6" Padding="10,8"
                                            Margin="0,8,0,0"
                                            Visibility="{Binding DatabaseSuccessMessage, Converter={StaticResource StringToVisibility}}">
                                        <TextBlock Text="{Binding DatabaseSuccessMessage}" FontSize="12"
                                                   Foreground="{StaticResource Success}" TextWrapping="Wrap"/>
                                    </Border>
                                    <Border Background="{StaticResource ErrorLight}" CornerRadius="6" Padding="10,8"
                                            Margin="0,6,0,0"
                                            Visibility="{Binding DatabaseErrorMessage, Converter={StaticResource StringToVisibility}}">
                                        <TextBlock Text="{Binding DatabaseErrorMessage}" FontSize="12"
                                                   Foreground="{StaticResource Error}" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Right: XPD sync card -->
                            <Border Grid.Row="0" Grid.Column="2" Background="{StaticResource Surface}"
                                    CornerRadius="10" BorderBrush="{StaticResource Border}" BorderThickness="1"
                                    Padding="24,20" Margin="0,0,0,24">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="0"/>
                                </Border.Effect>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="&#xE895;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="16" Foreground="{StaticResource Primary}"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="XPD → SQLite sync" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="Pull data from XPD (Access) into the app database. Set file path and credentials below."
                                               FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,0,0,18"/>

                                    <TextBlock Text="Paths" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                                    <TextBlock Text="SQLite database" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding DatabasePath, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="10,8" Margin="0,0,8,0" IsReadOnly="True"
                                                 Background="{StaticResource Divider}" FontSize="12"/>
                                        <Button Grid.Column="1" Content="Browse" Click="BrowseDatabasePath_Click"
                                                Style="{StaticResource GhostButton}" Padding="10,6" MinWidth="60"/>
                                    </Grid>

                                    <TextBlock Text="XPD file (.XPD)" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding XpdFilePath, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="10,8" Margin="0,0,8,0" FontSize="12"/>
                                        <Button Grid.Column="1" Content="Browse" Click="BrowseXpdPath_Click"
                                                Style="{StaticResource GhostButton}" Padding="10,6" MinWidth="60"/>
                                    </Grid>

                                    <Border Height="1" Background="{StaticResource Divider}" Margin="0,4,0,14"/>
                                    <TextBlock Text="XPD credentials (required for sync)" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                                    <TextBlock Text="User" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding XpdUser, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8" Margin="0,0,0,10" FontSize="12"/>
                                    <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                            BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <PasswordBox x:Name="XpdPasswordBox" Grid.Column="0"
                                                         Style="{StaticResource PasswordFieldPasswordBox}"
                                                         Padding="10,8,4,8" FontSize="12"
                                                         PasswordChanged="XpdPasswordBox_PasswordChanged"
                                                         Visibility="{Binding ShowXpdPassword, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                                            <TextBox x:Name="XpdPasswordTextBox" Grid.Column="0"
                                                     Style="{StaticResource PasswordFieldTextBox}"
                                                     Text="{Binding XpdPassword, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="10,8,4,8" FontSize="12"
                                                     Visibility="{Binding ShowXpdPassword, Converter={StaticResource BoolToVisibility}}"/>
                                            <Button Grid.Column="1" Click="ToggleXpdPasswordVisibility_Click"
                                                    Style="{StaticResource PasswordEyeButton}"
                                                    VerticalAlignment="Stretch" ToolTip="Show / hide password">
                                                <TextBlock x:Name="XpdPasswordEyeIcon" Text="&#xE7B3;"
                                                           FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="MDW path (required)" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding XpdMdwPath, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="10,8" Margin="0,0,8,0" FontSize="12"/>
                                        <Button Grid.Column="1" Content="Browse" Click="BrowseMdwPath_Click"
                                                Style="{StaticResource GhostButton}" Padding="10,6" MinWidth="60"/>
                                    </Grid>

                                    <!-- Persisted-password indicator: shown when API confirms password is on disk and field is empty -->
                                    <TextBlock Margin="0,0,0,10" FontSize="11" Foreground="{StaticResource TextMuted}"
                                               TextWrapping="Wrap"
                                               Text="A password is already saved. Type a new one only if you want to change it.">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding XpdPasswordPersisted}" Value="True"/>
                                                            <Condition Binding="{Binding XpdPassword}" Value=""/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Save configuration: persists path/credentials so BOTH manual and hourly auto-sync use them -->
                                    <Button Command="{Binding SaveDatabaseConfigCommand}"
                                            IsEnabled="{Binding DatabaseConfigSaving, Converter={StaticResource InvertBool}}"
                                            Style="{StaticResource PrimaryButton}"
                                            Padding="14,9" FontSize="12" FontWeight="SemiBold"
                                            HorizontalAlignment="Stretch" Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE74E;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Save configuration" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <TextBlock Text="{Binding DatabaseConfigSaveMessage}" FontSize="11"
                                               Foreground="{StaticResource Primary}" TextWrapping="Wrap"
                                               Margin="0,0,0,12"
                                               Visibility="{Binding DatabaseConfigSaveMessage, Converter={StaticResource StringToVisibility}}"/>

                                    <Border Height="1" Background="{StaticResource Divider}" Margin="0,2,0,12"/>

                                    <!-- Pre-flight: one-shot health check so the operator knows go/no-go before clicking Run -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="&#xE9F5;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="13" Foreground="{StaticResource TextSecondary}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Pre-flight check" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <Border CornerRadius="6" Padding="10,8" Margin="0,0,0,8" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F1F5F9"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PreflightStatus}" Value="ready">
                                                        <Setter Property="Background" Value="#ECFDF5"/>
                                                        <Setter Property="BorderBrush" Value="#A7F3D0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PreflightStatus}" Value="blocked">
                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                        <Setter Property="BorderBrush" Value="#FCD34D"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding PreflightSummary}" FontSize="11"
                                                       FontWeight="SemiBold" TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       Margin="0,0,0,4"/>
                                            <ItemsControl ItemsSource="{Binding PreflightBlockers}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="{Binding AutoSyncStatusMessage}" FontSize="11"
                                                       Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"
                                                       Margin="0,6,0,0"
                                                       Visibility="{Binding AutoSyncStatusMessage, Converter={StaticResource StringToVisibility}}"/>
                                        </StackPanel>
                                    </Border>

                                    <Button Command="{Binding LoadPreflightCommand}"
                                            IsEnabled="{Binding PreflightBusy, Converter={StaticResource InvertBool}}"
                                            Style="{StaticResource GhostButton}"
                                            Padding="12,7" FontSize="11" Margin="0,0,0,16"
                                            HorizontalAlignment="Stretch"
                                            Content="Re-run pre-flight check"/>

                                    <Border Background="#EFF6FF" CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                                            Visibility="{Binding SyncInProgress, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SyncProgressMessage}" FontSize="12"
                                                       Foreground="{StaticResource Primary}" FontWeight="SemiBold"
                                                       TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <ProgressBar Value="{Binding SyncProgressPercent}" Minimum="0" Maximum="100"
                                                         Height="6" Foreground="{StaticResource Primary}"
                                                         Background="{StaticResource Divider}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#F0F9FF" CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                                        <TextBlock Text="{Binding LastSyncInfo}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                    </Border>
                                    <Button Command="{Binding TriggerXpdSyncCommand}"
                                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                                            Style="{StaticResource PrimaryButton}"
                                            Padding="20,11" FontSize="13" FontWeight="SemiBold"
                                            HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE895;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Run sync now" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- ── Hourly auto-sync (toggles XpdSyncScheduler via xpd_sync_config.json) ── -->
                                    <Border Height="1" Background="{StaticResource Divider}" Margin="0,16,0,12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="&#xE823;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="13" Foreground="{StaticResource TextSecondary}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Hourly auto-sync" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="When enabled, the API runs a full XPD sync in the background on a recurring interval -- no clicks required. Status updates live; restart not needed."
                                               FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"
                                               Margin="0,0,0,10"/>

                                    <CheckBox IsChecked="{Binding XpdSchedulerEnabled}"
                                              Content="Enable hourly auto-sync"
                                              FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Sync interval (minutes)" FontSize="11"
                                                   Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Width="80"
                                                 Text="{Binding XpdSchedulerIntervalMinutes, UpdateSourceTrigger=PropertyChanged}"
                                                 IsEnabled="{Binding XpdSchedulerEnabled}"
                                                 FontSize="12" Padding="6,4" HorizontalContentAlignment="Right"/>
                                    </Grid>

                                    <CheckBox IsChecked="{Binding XpdSchedulerRunOnStartup}"
                                              IsEnabled="{Binding XpdSchedulerEnabled}"
                                              Content="Run sync once 15s after the app starts"
                                              FontSize="11" Margin="0,0,0,10"/>

                                    <Border Background="#F0F9FF" CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE9F5;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="11" Foreground="{StaticResource Primary}"
                                                       VerticalAlignment="Top" Margin="0,1,8,0"/>
                                            <TextBlock Text="{Binding XpdSchedulerStatusText}"
                                                       FontSize="11" Foreground="{StaticResource TextSecondary}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Command="{Binding SaveXpdSchedulerConfigCommand}"
                                                IsEnabled="{Binding XpdSchedulerSaveBusy, Converter={StaticResource InvertBool}}"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="14,9" FontSize="12" FontWeight="SemiBold"
                                                HorizontalAlignment="Stretch" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE74E;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Save auto-sync settings" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1"
                                                Command="{Binding RefreshXpdSchedulerStatusCommand}"
                                                Style="{StaticResource GhostButton}"
                                                Padding="12,7" FontSize="11"
                                                Content="Refresh"
                                                ToolTip="Re-read the live scheduler status from the API"/>
                                    </Grid>
                                    <TextBlock Text="{Binding XpdSchedulerSaveMessage}" FontSize="11"
                                               Foreground="{StaticResource Primary}" TextWrapping="Wrap"
                                               Margin="0,4,0,0"
                                               Visibility="{Binding XpdSchedulerSaveMessage, Converter={StaticResource StringToVisibility}}"/>
                                </StackPanel>
                            </Border>

                            <!-- Full-width note -->
                            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Background="{StaticResource Surface}"
                                    CornerRadius="8" BorderBrush="{StaticResource Border}" BorderThickness="1"
                                    Padding="14,12" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE946;" FontFamily="{StaticResource IconFont}"
                                               FontSize="14" Foreground="{StaticResource TextMuted}" VerticalAlignment="Top" Margin="0,0,8,0"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap">
                                        <Run Text="Click " FontWeight="Normal"/>
                                        <Run Text="Save configuration" FontWeight="SemiBold"/>
                                        <Run Text=" once per store. Both manual sync and the hourly auto-sync will then use these settings — no editing files in Program Files, no API restart."/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- Phone Numbers -->
                <TabItem Header="Phone Numbers" Loaded="PhoneNumbersTab_Loaded" x:Name="PhoneNumbersTab">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <StackPanel MaxWidth="640">
                            <!-- Store: combobox to select + Add new button opens dialog (HQ only) -->
                            <Border Background="{StaticResource Surface}" CornerRadius="10" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" Padding="24,20" Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="0"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Store" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Select the store to use for this session. Click Save to apply."
                                               FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,0,0,14"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableStores}"
                                                  DisplayMemberPath="StoreName" SelectedValuePath="StoreId"
                                                  SelectedValue="{Binding SelectedStoreId, UpdateSourceTrigger=PropertyChanged}"
                                                  MinWidth="200" MaxWidth="280" Padding="12,8" FontSize="14"
                                                  Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                                        <Button Grid.Column="1" Command="{Binding SaveStoreSelectionCommand}"
                                                Style="{StaticResource PrimaryButton}"
                                                MinHeight="36" Padding="14,0" Margin="0,0,8,0"
                                                VerticalAlignment="Center" ToolTip="Save store selection">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE74E;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="14" Foreground="{StaticResource TextOnPrimary}"
                                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Grid.Column="1" Text="Save" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextOnPrimary}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>
                                        <Button x:Name="AddNewStoreButton" Grid.Column="2"
                                                Click="AddNewStoreButton_Click"
                                                Style="{StaticResource GhostButton}"
                                                MinHeight="36" Padding="12,0"
                                                VerticalAlignment="Center"
                                                ToolTip="Add new store"
                                                Visibility="{Binding IsHqUser, Converter={StaticResource BoolToVisibility}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="&#xE710;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="14" Foreground="{StaticResource Primary}"
                                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Grid.Column="1" Text="Add new" FontSize="13"
                                                           Foreground="{StaticResource Primary}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>
                                    </Grid>

                                    <TextBlock Text="{Binding StoreSaveMessage}" FontSize="12"
                                               Foreground="{StaticResource Success}" Margin="0,8,0,0"
                                               Visibility="{Binding StoreSaveMessage, Converter={StaticResource StringToVisibility}}"/>
                                </StackPanel>
                            </Border>

                            <!-- Header -->
                            <DockPanel Margin="0,0,0,20">
                                <Button DockPanel.Dock="Right" Command="{Binding LoadPhoneNumbersCommand}"
                                        ToolTip="Refresh list" Padding="12,8" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="14" Foreground="{StaticResource TextSecondary}" Margin="0,0,6,0"/>
                                        <TextBlock Text="Refresh" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                                    </StackPanel>
                                </Button>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="&#xE717;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="18" Foreground="{StaticResource Primary}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="Twilio Phone Numbers" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="Manage numbers used for sending SMS. Set one as default for new messages."
                                               FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DockPanel>

                            <!-- Add number card -->
                            <Border Background="{StaticResource Surface}" CornerRadius="10" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" Padding="20,18" Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="0"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Add phone number" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6"/>
                                    <TextBlock Text="Enter a phone number (e.g. +1234567890) or Twilio number SID to add it to the current store."
                                               FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,0,0,14"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding NewPhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="12,10" FontSize="14" VerticalContentAlignment="Center"
                                                 Margin="0,0,10,0"/>
                                        <Button Grid.Column="1" Command="{Binding AddPhoneNumberCommand}"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="16,10" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Foreground="{StaticResource TextOnPrimary}" Margin="0,0,6,0"/>
                                                <TextBlock Text="Add number" FontSize="13" Foreground="{StaticResource TextOnPrimary}"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Error message -->
                            <Border Background="{StaticResource ErrorLight}" CornerRadius="8" Padding="14,10"
                                    Margin="0,0,0,16"
                                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE783;" FontFamily="{StaticResource IconFont}"
                                               FontSize="14" Foreground="{StaticResource Error}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}"
                                               FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Your numbers -->
                            <TextBlock Text="Your numbers" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>

                            <!-- Empty state -->
                            <Border Visibility="{Binding PhoneNumbers.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=WhenZero}"
                                    Background="{StaticResource Surface}" CornerRadius="8" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" Padding="24,32" Margin="0,0,0,12">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE717;" FontFamily="{StaticResource IconFont}" FontSize="28"
                                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="No phone numbers yet" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Add one using the form above to get started."
                                               FontSize="12" Foreground="{StaticResource TextMuted}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Number cards list -->
                            <ItemsControl ItemsSource="{Binding PhoneNumbers}"
                                          Visibility="{Binding PhoneNumbers.Count, Converter={StaticResource CountToVisibility}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Surface}" CornerRadius="8" BorderBrush="{StaticResource Border}"
                                                BorderThickness="1" Padding="16,14" Margin="0,0,0,10">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000" Opacity="0.03" BlurRadius="8" ShadowDepth="0"/>
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Vertical">
                                                    <TextBlock Text="{Binding Phone}" FontSize="15" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimary}"/>
                                                    <TextBlock Text="{Binding Sid}" FontSize="12" Foreground="{StaticResource TextMuted}"
                                                               Margin="0,2,0,0"
                                                               Visibility="{Binding Sid, Converter={StaticResource StringToVisibility}}"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                        <Border Background="{StaticResource PrimaryLight}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0"
                                                                Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibility}}">
                                                            <TextBlock Text="Default" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Primary}"/>
                                                        </Border>
                                                        <Border Background="{StaticResource SuccessLight}" CornerRadius="4" Padding="6,2"
                                                                Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}">
                                                            <TextBlock Text="Active" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Success}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Command="{Binding DataContext.SetDefaultNumberCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding NumberId}"
                                                            ToolTip="Set as default" Padding="8,6" Margin="0,0,6,0"
                                                            Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                                        <TextBlock Text="&#xE734;" FontFamily="{StaticResource IconFont}"
                                                                   FontSize="14" Foreground="{StaticResource TextSecondary}"/>
                                                    </Button>
                                                    <Button Command="{Binding DataContext.DeletePhoneNumberCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding NumberId}"
                                                            ToolTip="Remove number" Padding="8,6">
                                                        <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}"
                                                                   FontSize="14" Foreground="{StaticResource Error}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Twilio -->
                <TabItem Header="Twilio" Loaded="TwilioTab_Loaded">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <StackPanel MaxWidth="560">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE72E;" FontFamily="{StaticResource IconFont}"
                                           FontSize="18" Foreground="{StaticResource Primary}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Twilio API credentials" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Account SID and Auth Token from your Twilio console. Used to send SMS and manage phone numbers."
                                       FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                            <!-- Live/Mock status banner -->
                            <Border CornerRadius="8" BorderThickness="1" Padding="14,12" Margin="0,0,0,20">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource SuccessLight}"/>
                                        <Setter Property="BorderBrush" Value="#FF8FCC9F"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TwilioIsMock}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource ErrorLight}"/>
                                                <Setter Property="BorderBrush" Value="#FFE38C8C"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="{StaticResource IconFont}" FontSize="16"
                                               VerticalAlignment="Top" Margin="0,2,10,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#xE73E;"/>
                                                <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TwilioIsMock}" Value="True">
                                                        <Setter Property="Text" Value="&#xE7BA;"/>
                                                        <Setter Property="Foreground" Value="{StaticResource Error}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <StackPanel>
                                        <TextBlock FontSize="13" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="LIVE — outbound SMS will reach customers"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TwilioIsMock}" Value="True">
                                                            <Setter Property="Text" Value="MOCK MODE — outbound SMS NOT delivered"/>
                                                            <Setter Property="Foreground" Value="{StaticResource Error}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding TwilioStatusMessage}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0" MaxWidth="460"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource Surface}" CornerRadius="10" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" Padding="20,18" Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="0"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Account SID" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding TwilioSid, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" FontSize="14" Margin="0,0,0,16"/>

                                    <TextBlock Text="Auth Token" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                            BorderThickness="1" CornerRadius="6" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <PasswordBox x:Name="TwilioTokenPasswordBox" Grid.Column="0"
                                                         Style="{StaticResource PasswordFieldPasswordBox}"
                                                         Padding="12,10,4,10" FontSize="14"
                                                         PasswordChanged="TwilioTokenPassword_PasswordChanged"
                                                         Visibility="{Binding ShowTwilioToken, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                                            <TextBox x:Name="TwilioTokenTextBox" Grid.Column="0"
                                                     Style="{StaticResource PasswordFieldTextBox}"
                                                     Text="{Binding TwilioToken, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="12,10,4,10" FontSize="14"
                                                     Visibility="{Binding ShowTwilioToken, Converter={StaticResource BoolToVisibility}}"/>
                                            <Button Grid.Column="1" Click="ToggleTwilioTokenVisibility_Click"
                                                    Style="{StaticResource PasswordEyeButton}"
                                                    VerticalAlignment="Stretch" ToolTip="Show / hide token">
                                                <TextBlock x:Name="TwilioTokenEyeIcon" Text="&#xE7B3;"
                                                           FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="Messaging Service SID (optional, for US A2P / 10DLC)" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding TwilioMessagingServiceSid, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" FontSize="14" Margin="0,0,0,4"
                                             ToolTip="Starts with MG… If your Twilio account requires sending through a Messaging Service (typical for US long codes), put the SID here."/>
                                    <TextBlock Text="Leave blank if you only use direct From numbers."
                                               FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>

                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding SaveTwilioConfigCommand}"
                                                IsEnabled="{Binding TwilioSaveBusy, Converter={StaticResource InvertBool}, FallbackValue=True}"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="16,10" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE74E;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Foreground="{StaticResource TextOnPrimary}" Margin="0,0,8,0"/>
                                                <TextBlock Text="Save &amp; verify" FontSize="13" Foreground="{StaticResource TextOnPrimary}"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding RefreshTwilioStatusCommand}"
                                                Padding="16,10" Margin="10,0,0,0" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Margin="0,0,8,0"
                                                           Foreground="{StaticResource TextPrimary}"/>
                                                <TextBlock Text="Re-check status" FontSize="13"
                                                           Foreground="{StaticResource TextPrimary}"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <TextBlock Text="{Binding TwilioSaveMessage}" FontSize="12" Margin="0,12,0,0"
                                               Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"
                                               Visibility="{Binding TwilioSaveMessage, Converter={StaticResource StringToVisibility}}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Reminders -->
                <TabItem Header="Reminders" Loaded="RemindersTab_Loaded">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <StackPanel MaxWidth="560">
                            <DockPanel Margin="0,0,0,20">
                                <Button DockPanel.Dock="Right" Command="{Binding LoadSchedulerStatusCommand}"
                                        ToolTip="Refresh status" Padding="12,8" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="14" Foreground="{StaticResource TextSecondary}" Margin="0,0,6,0"/>
                                        <TextBlock Text="Refresh" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                                    </StackPanel>
                                </Button>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="&#xE823;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="18" Foreground="{StaticResource Primary}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="Reminder scheduler" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="Background job that sends due-date reminders. Start or stop it here and see daily usage."
                                               FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DockPanel>

                            <Border Background="{StaticResource Surface}" CornerRadius="10" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" Padding="20,18" Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="0"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Status" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="SchedulerStatusIndicator" Width="10" Height="10" CornerRadius="5"
                                                Margin="0,0,10,0" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource TextMuted}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SchedulerRunning}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Success}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="Running" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Success}"
                                                       Visibility="{Binding SchedulerRunning, Converter={StaticResource BoolToVisibility}}"/>
                                            <TextBlock Text="Stopped" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMuted}"
                                                       Visibility="{Binding SchedulerRunning, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="Next run" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding SchedulerNextRun}" FontSize="14"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,14"/>

                                    <TextBlock Text="Sent today" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                    <TextBlock FontSize="14" Foreground="{StaticResource TextPrimary}">
                                        <Run Text="{Binding DailySent, Mode=OneWay}" FontWeight="SemiBold"/>
                                        <Run Text=" / "/>
                                        <Run Text="{Binding DailyLimit, Mode=OneWay}"/>
                                        <Run Text=" reminders"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Controls" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Button Command="{Binding StartSchedulerCommand}"
                                        Style="{StaticResource SuccessButton}"
                                        Padding="18,10" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE768;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="13" Foreground="White" Margin="0,0,6,0"/>
                                        <TextBlock Text="Start scheduler" FontSize="13" Foreground="White"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding StopSchedulerCommand}"
                                        Style="{StaticResource DangerButton}"
                                        Padding="18,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="13" Foreground="White" Margin="0,0,6,0"/>
                                        <TextBlock Text="Stop scheduler" FontSize="13" Foreground="White"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <TextBlock Text="Manual Run" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>
                            <TextBlock Text="Run reminders immediately without waiting for the scheduled time. Processes all eligible tickets across all stores."
                                       FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <Button Command="{Binding RunRemindersNowCommand}"
                                    IsEnabled="{Binding RunNowBusy, Converter={StaticResource InvertBool}}"
                                    Padding="18,10" Margin="0,0,0,8">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="{StaticResource Primary}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE768;" FontFamily="{StaticResource IconFont}"
                                               FontSize="13" Foreground="White" Margin="0,0,6,0"/>
                                    <TextBlock FontSize="13" Foreground="White">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Run reminders now"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RunNowBusy}" Value="True">
                                                        <Setter Property="Text" Value="Running..."/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                            <!-- Progress bar: visible during a reminder run -->
                            <Border Background="{StaticResource Surface}" CornerRadius="10" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" Padding="18,14" Margin="0,12,0,0"
                                    Visibility="{Binding ReminderRunActive, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock DockPanel.Dock="Right" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                                   VerticalAlignment="Center">
                                            <Run Text="{Binding ReminderProgressProcessed, Mode=OneWay}"/>
                                            <Run Text=" / "/>
                                            <Run Text="{Binding ReminderProgressTotal, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}">
                                            <Run Text="Sending: "/>
                                            <Run Text="{Binding ReminderProgressPhase, Mode=OneWay}"/>
                                        </TextBlock>
                                    </DockPanel>
                                    <ProgressBar Height="8" Minimum="0"
                                                 Maximum="{Binding ReminderProgressTotal, FallbackValue=1}"
                                                 Value="{Binding ReminderProgressProcessed, Mode=OneWay}"
                                                 Foreground="{StaticResource Primary}" Background="{StaticResource Border}"
                                                 Margin="0,0,0,8">
                                        <ProgressBar.Style>
                                            <Style TargetType="ProgressBar">
                                                <Setter Property="IsIndeterminate" Value="False"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ReminderProgressTotal}" Value="0">
                                                        <Setter Property="IsIndeterminate" Value="True"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ProgressBar.Style>
                                    </ProgressBar>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="12" Foreground="{StaticResource Success}" Margin="0,0,12,0">
                                            <Run Text="{Binding ReminderProgressSent, Mode=OneWay}"/>
                                            <Run Text=" sent"/>
                                        </TextBlock>
                                        <TextBlock FontSize="12" Foreground="{StaticResource Error}" Margin="0,0,12,0">
                                            <Run Text="{Binding ReminderProgressFailed, Mode=OneWay}"/>
                                            <Run Text=" failed"/>
                                        </TextBlock>
                                        <TextBlock FontSize="12" Foreground="{StaticResource TextMuted}">
                                            <Run Text="{Binding ReminderProgressSkipped, Mode=OneWay}"/>
                                            <Run Text=" skipped"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="{Binding RunNowResult}" FontSize="13"
                                       Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"
                                       Visibility="{Binding RunNowResult, Converter={StaticResource StringToVisibility}}"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- VoIP -->
                <TabItem Header="VoIP" Loaded="VoipTab_Loaded">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <StackPanel MaxWidth="560">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE717;" FontFamily="{StaticResource IconFont}"
                                           FontSize="18" Foreground="{StaticResource Primary}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="XBlue VoIP (click-to-call)" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Connect to a Fanvil IP phone (e.g. IP9G) via XBlue so you can dial from the app with one click."
                                       FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                            <Border Background="{StaticResource Surface}" CornerRadius="10" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" Padding="20,18" Margin="0,0,0,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="0"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                            BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
                                        <CheckBox Content="Enable XBlue VoIP" IsChecked="{Binding XblueEnabled}"
                                                  FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                                    </Border>
                                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                            BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,16">
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding XblueSpeakerBeforeDial}"
                                                      FontSize="14" Foreground="{StaticResource TextPrimary}">
                                                <TextBlock TextWrapping="Wrap"
                                                           Text="Speaker before dial (recommended — opens hands-free so Fanvil can complete the call)"/>
                                            </CheckBox>
                                            <CheckBox IsChecked="{Binding XbluePressPoundToSend}"
                                                      Margin="0,12,0,0"
                                                      FontSize="14" Foreground="{StaticResource TextPrimary}">
                                                <TextBlock TextWrapping="Wrap"
                                                           Text="Press # to send (matches Fanvil Dial Plan — Press # to invoke dialing; sends POUND after digits instead of ENTER)"/>
                                            </CheckBox>
                                        </StackPanel>
                                    </Border>
                                    <Button Command="{Binding OpenFanvilWebUiCommand}"
                                            Style="{StaticResource GhostButton}"
                                            Padding="12,8" HorizontalAlignment="Left" Margin="0,0,0,16">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE774;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Open phone web page (default browser)" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <TextBlock Text="XBlue IP address" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <TextBlock Text="IP or hostname of the phone (e.g. 192.168.2.96 for IP9G on LAN)"
                                               FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding XblueIp, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" FontSize="14" MaxWidth="320" HorizontalAlignment="Left"
                                             Margin="0,0,0,12"/>

                                    <TextBlock Text="Outbound prefix (PBX)" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <TextBlock Text="Digits to dial before 10-digit numbers only (e.g. 9 for an outside line). Leave blank for extensions."
                                               FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding XblueOutboundPrefix, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" FontSize="14" MaxWidth="120" HorizontalAlignment="Left"
                                             Margin="0,0,0,16"/>

                                    <TextBlock Text="Phone web login (HTTP Basic)" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <TextBlock Text="Same as the Fanvil web UI — used for ConfigManApp.com (dial, volume, etc.)."
                                               FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <TextBlock Text="Username" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding XblueUsername, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" FontSize="14" MaxWidth="320" HorizontalAlignment="Left"
                                             Margin="0,0,0,10"/>
                                    <TextBlock Text="Password" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                    <PasswordBox x:Name="XbluePasswordBox"
                                                 Style="{StaticResource PasswordFieldPasswordBox}"
                                                 Padding="12,10" FontSize="14" MaxWidth="320" HorizontalAlignment="Left"
                                                 PasswordChanged="XbluePasswordBox_PasswordChanged"
                                                 Margin="0,0,0,16"/>

                                    <TextBlock Text="Test from this PC" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Button Command="{Binding TestVoipConnectionCommand}"
                                                IsEnabled="{Binding XblueVoipTestBusy, Converter={StaticResource InvertBool}}"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="16,10" Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE72E;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Test connection" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding VoipVolumeUpCommand}"
                                                IsEnabled="{Binding XblueVoipTestBusy, Converter={StaticResource InvertBool}}"
                                                Style="{StaticResource GhostButton}"
                                                Padding="16,10" Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE767;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Volume up" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding VoipDialCommand}"
                                                IsEnabled="{Binding XblueVoipTestBusy, Converter={StaticResource InvertBool}}"
                                                Style="{StaticResource GhostButton}"
                                                Padding="16,10" Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE717;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Dial" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Button Command="{Binding VoipSpeakerCommand}"
                                                IsEnabled="{Binding XblueVoipTestBusy, Converter={StaticResource InvertBool}}"
                                                Style="{StaticResource GhostButton}"
                                                Padding="16,10" Margin="0,0,10,0"
                                                ToolTip="Toggles speakerphone so call audio plays louder in the room">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE8B7;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Speaker" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding VoipUnmuteCommand}"
                                                IsEnabled="{Binding XblueVoipTestBusy, Converter={StaticResource InvertBool}}"
                                                Style="{StaticResource GhostButton}"
                                                Padding="16,10"
                                                ToolTip="Toggles mute — use if the handset has no sound">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE74F;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Unmute / mute" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <TextBlock Text="Extension or number" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding XblueDialTarget, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" FontSize="14" MaxWidth="200" HorizontalAlignment="Left"
                                             Margin="0,0,0,12"/>
                                    <TextBlock Text="Volume up raises ring/call level. Speaker toggles handsfree. Unmute/mute toggles the mic/audio mute. Dial sends the extension or number below. All require VoIP enabled except Test connection."
                                               FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <Border Background="{StaticResource Surface}" CornerRadius="6"
                                            Padding="14,12" BorderBrush="{StaticResource Border}" BorderThickness="1"
                                            Visibility="{Binding XblueVoipTestSummary, Converter={StaticResource StringToVisibility}}">
                                        <TextBlock Text="{Binding XblueVoipTestSummary}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Reviews -->
                <TabItem Header="Reviews" Loaded="ReviewsTab_Loaded">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <StackPanel MaxWidth="560">
                            <!-- XPD new-ticket review automation (server) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE823;" FontFamily="{StaticResource IconFont}"
                                           FontSize="18" Foreground="{StaticResource Primary}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="New ticket review requests" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="The API checks synced XPD tickets on a schedule. When new ticket numbers appear, one review SMS is sent per customer (phone: home, then business, then numbers in notes). Review links rotate using your channels below. Settings are stored on the API next to the database."
                                       FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                            <Border Background="{StaticResource Surface}" CornerRadius="10" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" Padding="20,18" Margin="0,0,0,24">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="0"/>
                                </Border.Effect>
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,12">
                                        <Button DockPanel.Dock="Right" Command="{Binding LoadReviewAutomationCommand}"
                                                ToolTip="Reload settings" Padding="10,6" Cursor="Hand">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,0,5,0"/>
                                                <TextBlock Text="Refresh" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            </StackPanel>
                                        </Button>
                                        <StackPanel>
                                            <TextBlock Text="Automation schedule" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="10" Height="10" CornerRadius="5" Margin="0,0,10,0" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource TextMuted}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ReviewAutoTimerRunning}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource Success}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <TextBlock Text="Timer" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="active" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Success}"
                                                               Visibility="{Binding ReviewAutoTimerRunning, Converter={StaticResource BoolToVisibility}}"/>
                                                    <TextBlock Text="off" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"
                                                               Visibility="{Binding ReviewAutoTimerRunning, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="{Binding ReviewAutoSettingsPath}" FontSize="11"
                                                       Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"
                                                       Visibility="{Binding ReviewAutoSettingsPath, Converter={StaticResource StringToVisibility}}"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                            BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
                                        <CheckBox Content="Enable automatic review SMS when new XPD tickets sync"
                                                  IsChecked="{Binding ReviewAutoEnabled}"
                                                  FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                                    </Border>

                                    <TextBlock Text="Check every (minutes)" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding ReviewAutoIntervalMinutes, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8" FontSize="14" MaxWidth="120" HorizontalAlignment="Left" Margin="0,0,0,12"/>

                                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                            BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,16">
                                        <CheckBox Content="Run first check immediately when the API starts (then on schedule)"
                                                  IsChecked="{Binding ReviewAutoRunOnStartup}"
                                                  FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                                    </Border>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Button Command="{Binding SaveReviewAutomationCommand}"
                                                Style="{StaticResource PrimaryButton}" Padding="16,9" Margin="0,0,10,0"
                                                IsEnabled="{Binding ReviewAutoBusy, Converter={StaticResource InvertBool}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE74E;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Foreground="{StaticResource TextOnPrimary}" Margin="0,0,8,0"/>
                                                <TextBlock Text="Save automation settings" FontSize="13" Foreground="{StaticResource TextOnPrimary}"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding RunReviewAutomationNowCommand}"
                                                Padding="16,9"
                                                IsEnabled="{Binding ReviewAutoBusy, Converter={StaticResource InvertBool}}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Background" Value="{StaticResource Primary}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE768;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Foreground="White" Margin="0,0,6,0"/>
                                                <TextBlock FontSize="13" Foreground="White">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Run check now"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ReviewAutoBusy}" Value="True">
                                                                    <Setter Property="Text" Value="Working..."/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <TextBlock Text="{Binding ReviewAutoStatusMessage}" FontSize="13"
                                               Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"
                                               Visibility="{Binding ReviewAutoStatusMessage, Converter={StaticResource StringToVisibility}}"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE735;" FontFamily="{StaticResource IconFont}"
                                           FontSize="18" Foreground="{StaticResource Primary}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Review Channels" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Configure review platform URLs for your store. When a review request is sent, the system rotates through these channels automatically."
                                       FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                            <!-- Current channels list -->
                            <Border Background="{StaticResource Surface}" CornerRadius="10" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" Padding="18,14" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Active Channels" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding ReviewChannels}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="10,8" BorderBrush="{StaticResource Divider}" BorderThickness="0,0,0,1">
                                                    <DockPanel>
                                                        <Button DockPanel.Dock="Right"
                                                                Command="{Binding DataContext.DeleteReviewChannelCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding ReviewChannelId}"
                                                                Style="{StaticResource GhostButton}" Padding="6,3" FontSize="11"
                                                                Foreground="{StaticResource Error}" Content="Delete" VerticalAlignment="Center"/>
                                                        <StackPanel>
                                                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}">
                                                                <Run Text="{Binding PlatformName, Mode=OneWay}"/>
                                                                <Run Text=" (order: " Foreground="{StaticResource TextMuted}"/><Run Text="{Binding SortOrder, Mode=OneWay}" Foreground="{StaticResource TextMuted}"/><Run Text=")" Foreground="{StaticResource TextMuted}"/>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding ReviewUrl}" FontSize="11"
                                                                       Foreground="{StaticResource TextSecondary}"
                                                                       TextTrimming="CharacterEllipsis" MaxWidth="380"/>
                                                        </StackPanel>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No channels configured yet."
                                               FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,8,0,0"
                                               Visibility="{Binding ReviewChannels.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=WhenZero}"/>
                                </StackPanel>
                            </Border>

                            <!-- Add new channel -->
                            <Border Background="{StaticResource Surface}" CornerRadius="10" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" Padding="18,14">
                                <StackPanel>
                                    <TextBlock Text="Add Channel" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>

                                    <TextBlock Text="Platform" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <ComboBox SelectedValue="{Binding NewPlatformName}" SelectedValuePath="Content"
                                              Margin="0,0,0,12" MaxWidth="240" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Google"/>
                                        <ComboBoxItem Content="Yelp"/>
                                        <ComboBoxItem Content="BBB"/>
                                        <ComboBoxItem Content="Facebook"/>
                                        <ComboBoxItem Content="Trustpilot"/>
                                    </ComboBox>

                                    <TextBlock Text="Review URL" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewReviewUrl, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8" FontSize="13" Margin="0,0,0,14"/>

                                    <Button Command="{Binding AddReviewChannelCommand}"
                                            Style="{StaticResource PrimaryButton}" Padding="14,7" FontSize="13"
                                            HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Add Channel"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Status messages -->
                            <Border Background="{StaticResource ErrorLight}" CornerRadius="5" Padding="10,7" Margin="0,12,0,0"
                                    Visibility="{Binding ReviewErrorMessage, Converter={StaticResource StringToVisibility}}">
                                <TextBlock Text="{Binding ReviewErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"/>
                            </Border>
                            <Border Background="#E0F7EA" CornerRadius="5" Padding="10,7" Margin="0,8,0,0"
                                    Visibility="{Binding ReviewSuccessMessage, Converter={StaticResource StringToVisibility}}">
                                <TextBlock Text="{Binding ReviewSuccessMessage}" Foreground="{StaticResource Success}" FontSize="12"/>
                            </Border>

                            <!-- Sent History -->
                            <Border Height="1" Background="{StaticResource Divider}" Margin="0,20,0,16"/>

                            <DockPanel Margin="0,0,0,12">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Button Command="{Binding LoadReviewHistoryCommand}"
                                            ToolTip="Refresh history" Padding="10,6" Cursor="Hand" Margin="0,0,4,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,0,5,0"/>
                                            <TextBlock Text="Refresh" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ClearReviewHistoryCommand}"
                                            ToolTip="Delete all history" Padding="10,6" Cursor="Hand"
                                            Visibility="{Binding ReviewHistory.Count, Converter={StaticResource CountToVisibility}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}"
                                                       FontSize="13" Foreground="{StaticResource Error}" Margin="0,0,5,0"/>
                                            <TextBlock Text="Clear" FontSize="12" Foreground="{StaticResource Error}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="&#xE81C;" FontFamily="{StaticResource IconFont}"
                                                   FontSize="18" Foreground="{StaticResource Primary}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="Sent History" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                        <Border Background="{StaticResource Primary}" CornerRadius="9" Padding="7,2" Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding ReviewHistory.Count, Converter={StaticResource CountToVisibility}}">
                                            <TextBlock Text="{Binding ReviewHistory.Count}" FontSize="10.5" FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Review request messages sent from this store, most recent first."
                                               FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DockPanel>

                            <!-- Loading indicator -->
                            <Border Padding="16,12" Margin="0,0,0,8"
                                    Visibility="{Binding ReviewHistoryLoading, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE895;" FontFamily="{StaticResource IconFont}"
                                               FontSize="14" Foreground="{StaticResource TextMuted}" Margin="0,0,8,0"/>
                                    <TextBlock Text="Loading history..." FontSize="13" Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                            </Border>

                            <!-- Empty state -->
                            <Border Visibility="{Binding ReviewHistory.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=WhenZero}"
                                    Background="{StaticResource Surface}" CornerRadius="8" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" Padding="24,28" Margin="0,0,0,12">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE81C;" FontFamily="{StaticResource IconFont}" FontSize="28"
                                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="No review requests sent yet" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Sent review requests will appear here."
                                               FontSize="12" Foreground="{StaticResource TextMuted}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- History cards in fixed-height scrollable container -->
                            <Border Background="{StaticResource Surface}" CornerRadius="10" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" MaxHeight="400" Margin="0,0,0,8"
                                    Visibility="{Binding ReviewHistory.Count, Converter={StaticResource CountToVisibility}}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                                    <ItemsControl ItemsSource="{Binding ReviewHistory}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource Surface}" CornerRadius="6"
                                                        BorderBrush="{StaticResource Divider}" BorderThickness="0,0,0,1"
                                                        Padding="12,10" Margin="0,0,0,2">
                                                    <StackPanel>
                                                        <DockPanel Margin="0,0,0,4">
                                                            <!-- Status badge on the right -->
                                                            <Border DockPanel.Dock="Right" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{StaticResource PrimaryLight}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Delivered">
                                                                                <Setter Property="Background" Value="{StaticResource SuccessLight}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                                <Setter Property="Background" Value="{StaticResource ErrorLight}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{StaticResource Primary}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Delivered">
                                                                                    <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                                    <Setter Property="Foreground" Value="{StaticResource Error}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>

                                                            <!-- Left: phone + platform + date -->
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                                    <TextBlock Text="{Binding Phone}" FontSize="13" FontWeight="SemiBold"
                                                                               Foreground="{StaticResource TextPrimary}" Margin="0,0,8,0"/>
                                                                    <Border Background="{StaticResource PrimaryLight}" CornerRadius="4"
                                                                            Padding="6,2" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding PlatformName}" FontSize="10"
                                                                                   FontWeight="SemiBold" Foreground="{StaticResource Primary}"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding SentAtText}" FontSize="11"
                                                                           Foreground="{StaticResource TextMuted}"/>
                                                            </StackPanel>
                                                        </DockPanel>

                                                        <!-- Message body preview -->
                                                        <TextBlock Text="{Binding MessageBody}" FontSize="12"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   TextTrimming="CharacterEllipsis" MaxHeight="34"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <!-- Load more button -->
                            <Button Command="{Binding LoadMoreReviewHistoryCommand}"
                                    HorizontalAlignment="Center" Padding="20,8" Margin="0,4,0,0"
                                    Visibility="{Binding HasMoreHistory, Converter={StaticResource BoolToVisibility}}"
                                    IsEnabled="{Binding ReviewHistoryLoading, Converter={StaticResource InvertBool}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE70D;" FontFamily="{StaticResource IconFont}"
                                               FontSize="12" Foreground="{StaticResource TextSecondary}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Load more" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Quality -->
                <TabItem Header="Quality" Loaded="QualityTab_Loaded">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <StackPanel MaxWidth="720">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource IconFont}"
                                           FontSize="18" Foreground="{StaticResource Primary}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Customer Quality Query" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Define a custom SQL query that runs per customer to compute quality metrics. The query must use @customerKey as a parameter and return a single row. Each column becomes a metric displayed in the customer panel."
                                       FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                            <Border Background="{StaticResource Surface}" CornerRadius="10" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" Padding="20,18" Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="0"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="SQL Query" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding QualityQuery, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True"
                                             VerticalScrollBarVisibility="Auto"
                                             FontFamily="Consolas" FontSize="13"
                                             MinHeight="200" MaxHeight="400"
                                             Padding="12,10" Margin="0,0,0,16"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button Command="{Binding SaveQualityQueryCommand}"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="16,10" Margin="0,0,10,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE74E;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Foreground="{StaticResource TextOnPrimary}" Margin="0,0,8,0"/>
                                                <TextBlock Text="Save query" FontSize="13" Foreground="{StaticResource TextOnPrimary}"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding ResetQualityQueryCommand}"
                                                Style="{StaticResource GhostButton}"
                                                Padding="16,10">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0"/>
                                                <TextBlock Text="Reset to default" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource SuccessLight}" CornerRadius="8" Padding="14,10"
                                    Margin="0,0,0,6"
                                    Visibility="{Binding QualitySaveMessage, Converter={StaticResource StringToVisibility}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}"
                                               FontSize="14" Foreground="{StaticResource Success}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding QualitySaveMessage}" Foreground="{StaticResource Success}"
                                               FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{StaticResource ErrorLight}" CornerRadius="8" Padding="14,10"
                                    Margin="0,0,0,6"
                                    Visibility="{Binding QualityErrorMessage, Converter={StaticResource StringToVisibility}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE783;" FontFamily="{StaticResource IconFont}"
                                               FontSize="14" Foreground="{StaticResource Error}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding QualityErrorMessage}" Foreground="{StaticResource Error}"
                                               FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource Surface}" CornerRadius="8" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" Padding="14,12" Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE946;" FontFamily="{StaticResource IconFont}"
                                               FontSize="14" Foreground="{StaticResource TextMuted}" VerticalAlignment="Top" Margin="0,0,8,0"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextMuted}">
                                        <Run Text="Use @customerKey as the parameter. Return one row with named columns (e.g. tickets_closed, pfx_count, late_tickets, avg_days_late)."/>
                                        <LineBreak/>
                                        <Run Text="Risk is auto-classified: avg_days_late > 30 or pfx ≥ 3 or late ≥ 3 = High, > 7 or pfx/late ≥ 1 = Medium, else Low."/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- HQ Hub: connect this store to the central monitoring console. -->
                <TabItem Header="HQ Hub" Loaded="HubTab_Loaded">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <StackPanel MaxWidth="600">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE968;" FontFamily="{StaticResource IconFont}"
                                           FontSize="18" Foreground="{StaticResource Primary}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="HQ monitoring console" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Pushes a heartbeat to the central HQ Hub every minute so the operations team can see this store online and trigger remote actions (XPD sync, etc.)."
                                       FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                            <Border Background="{StaticResource Surface}" CornerRadius="10" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" Padding="18,16" Margin="0,0,0,16">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,12">
                                        <Button DockPanel.Dock="Right" Command="{Binding RefreshHubStatusCommand}"
                                                IsEnabled="{Binding HubStatusBusy, Converter={StaticResource InvertBool}}"
                                                Style="{StaticResource GhostButton}" Padding="12,7">
                                            <TextBlock Text="Refresh status" FontSize="12"/>
                                        </Button>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="10" Height="10" CornerRadius="5" Margin="0,0,8,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource Error}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HubIsConnected}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource Success}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            <TextBlock Text="{Binding HubConnectionStatus}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBlock Text="Effective Hub URL used by the API" FontSize="11"
                                               Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock Text="{Binding HubEffectiveUrl}" FontSize="12" FontFamily="Consolas"
                                               Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" Margin="0,2,0,10"/>

                                    <TextBlock Text="Last successful heartbeat" FontSize="11"
                                               Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock Text="{Binding HubLastSuccessText}" FontSize="12"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,2,0,10"/>

                                    <TextBlock Text="Last connection error" FontSize="11"
                                               Foreground="{StaticResource TextMuted}"/>
                                    <TextBlock Text="{Binding HubLastError}" FontSize="12"
                                               Foreground="{StaticResource Error}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource Surface}" CornerRadius="10" BorderBrush="{StaticResource Border}"
                                    BorderThickness="1" Padding="20,18" Margin="0,0,0,20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="0"/>
                                </Border.Effect>
                                <StackPanel>
                                    <CheckBox IsChecked="{Binding HubEnabled}" Content="Enable HQ Hub reporting"
                                              FontSize="13" FontWeight="SemiBold"
                                              Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                                    <TextBlock Text="Hub URL" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding HubUrl, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" FontSize="14" Margin="0,0,0,4"
                                             ToolTip="e.g. https://hq.example.com or http://localhost:5290"/>
                                    <TextBlock Text="Base URL of the HQ Hub server (no trailing slash)."
                                               FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>

                                    <TextBlock Text="Store Key (X-Store-Key)" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <Border Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                            BorderThickness="1" CornerRadius="6" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <PasswordBox x:Name="HubStoreKeyPasswordBox" Grid.Column="0"
                                                         Style="{StaticResource PasswordFieldPasswordBox}"
                                                         Padding="12,10,4,10" FontSize="14"
                                                         PasswordChanged="HubStoreKeyPassword_PasswordChanged"
                                                         Visibility="{Binding ShowHubStoreKey, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                                            <TextBox x:Name="HubStoreKeyTextBox" Grid.Column="0"
                                                     Style="{StaticResource PasswordFieldTextBox}"
                                                     Text="{Binding HubStoreKey, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="12,10,4,10" FontSize="14"
                                                     Visibility="{Binding ShowHubStoreKey, Converter={StaticResource BoolToVisibility}}"/>
                                            <Button Grid.Column="1" Command="{Binding ToggleShowHubStoreKeyCommand}"
                                                    Style="{StaticResource PasswordEyeButton}"
                                                    VerticalAlignment="Stretch" ToolTip="Show / hide key">
                                                <TextBlock Text="&#xE7B3;"
                                                           FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="Per-store API key generated by HQ when this store was added."
                                               FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>

                                    <TextBlock Text="Deployment ID" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding HubDeploymentId, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" FontSize="14" Margin="0,0,0,4"
                                             ToolTip="Stable identifier for this physical install (e.g. main-counter-pc, store-3-back)."/>
                                    <TextBlock Text="Must match the Deployment ID configured for this store on HQ."
                                               FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>

                                    <TextBlock Text="Heartbeat interval (seconds)" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding HubIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" FontSize="14" Margin="0,0,0,4" Width="120" HorizontalAlignment="Left"
                                             ToolTip="How often to push a heartbeat. 60 is a good default."/>
                                    <TextBlock Text="60 is the recommended value (also used as the offline threshold on HQ)."
                                               FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,20"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button Command="{Binding TestHubConnectionCommand}"
                                                IsEnabled="{Binding HubTestBusy, Converter={StaticResource InvertBool}, FallbackValue=True}"
                                                Padding="16,10" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE968;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Margin="0,0,8,0"
                                                           Foreground="{StaticResource TextPrimary}"/>
                                                <TextBlock Text="Test URL and Store Key" FontSize="13"
                                                           Foreground="{StaticResource TextPrimary}"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding SaveHubConfigCommand}"
                                                IsEnabled="{Binding HubSaveBusy, Converter={StaticResource InvertBool}, FallbackValue=True}"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="16,10" Margin="10,0,0,0" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE74E;" FontFamily="{StaticResource IconFont}"
                                                           FontSize="13" Foreground="{StaticResource TextOnPrimary}" Margin="0,0,8,0"/>
                                                <TextBlock Text="Save" FontSize="13" Foreground="{StaticResource TextOnPrimary}"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <!-- Test connection result -->
                                    <TextBlock Text="{Binding HubTestMessage}" FontSize="12" Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding HubTestMessage, Converter={StaticResource StringToVisibility}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource Error}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HubTestSuccess}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource Success}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Save result -->
                                    <TextBlock Text="{Binding HubSaveMessage}" FontSize="12" Margin="0,4,0,0"
                                               Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"
                                               Visibility="{Binding HubSaveMessage, Converter={StaticResource StringToVisibility}}"/>
                                </StackPanel>
                            </Border>

                            <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap">
                                <Run Text="Settings are saved to "/>
                                <Run Text="{Binding HubConfigPath, Mode=OneWay}" FontFamily="Consolas"/>
                                <Run Text=" and applied live by the bundled API after Save."/>
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
    </Border>
</UserControl>
