<UserControl x:Class="SmsOpsHQ.Desktop.Views.CustomerPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:CustomerPanelViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" Width="320"
             Loaded="OnLoaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,16,16,20">

            <!-- Customer header -->
            <TextBlock Text="{Binding CustomerName}" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                <TextBlock Text="{Binding CustomerPhone}" FontSize="12.5"
                           Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                <Button Command="{Binding ClickToCallCommand}"
                        Style="{StaticResource SuccessButton}"
                        Padding="8,2" Margin="8,0,0,0" FontSize="11" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE717;" FontFamily="{StaticResource IconFont}"
                                   FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Call"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Call status -->
            <TextBlock Text="{Binding CallStatus}" FontSize="11"
                       Foreground="{StaticResource Primary}" Margin="0,0,0,3"
                       Visibility="{Binding CallStatus, Converter={StaticResource StringToVisibility}}"/>

            <TextBlock Text="{Binding CustomerAddress}" FontSize="11.5"
                       Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"
                       Margin="0,0,0,14"/>

            <!-- Risk badge -->
            <Border Background="{Binding RiskColor}" CornerRadius="4" Padding="10,4"
                    HorizontalAlignment="Left" Margin="0,0,0,14">
                <TextBlock Text="{Binding RiskLevel}" Foreground="White" FontSize="11.5"
                           FontWeight="Bold"/>
            </Border>

            <!-- Stats grid -->
            <Border Background="{StaticResource Surface}" CornerRadius="8" Padding="14"
                    Margin="0,0,0,16"
                    BorderBrush="{StaticResource Border}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="ACTIVE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding ActiveCount}" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                        <TextBlock Text="LATE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding LateCount}" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource Error}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Text="PFX" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding PfxCount}" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource Warning}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                        <TextBlock Text="BALANCE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding TotalBalance, StringFormat='${0:N2}'}" FontSize="20"
                                   FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="LATE RATE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding LateRate, StringFormat='{}{0:N1}%'}" FontSize="14"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1">
                        <TextBlock Text="ALL TIME" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding AllTimeCount}" FontSize="14"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Active tickets -->
            <TextBlock Text="Active Tickets" FontSize="13" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding ActiveTickets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource Surface}" CornerRadius="6"
                                Padding="12,9" Margin="0,0,0,6"
                                BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" FontSize="11"
                                               Foreground="{StaticResource TextMuted}">
                                        <Run Text="$"/><Run Text="{Binding Balance, StringFormat='{}{0:N2}', Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}">
                                        <Run Text="#"/><Run Text="{Binding TransNo, Mode=OneWay}"/>
                                    </TextBlock>
                                </DockPanel>
                                <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0">
                                    <Run Text="Due: "/><Run Text="{Binding DueDate, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding Items}" FontSize="11"
                                           Foreground="{StaticResource TextSecondary}"
                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Notes -->
            <TextBlock Text="Notes" FontSize="13" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,14,0,6"/>
            <TextBox Text="{Binding CustomerNotes, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80"
                     FontSize="12" Margin="0,0,0,6"/>
            <Button Content="Save Notes" Command="{Binding SaveNotesCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Padding="12,6" FontSize="12" HorizontalAlignment="Left"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
