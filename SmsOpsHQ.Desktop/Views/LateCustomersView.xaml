<UserControl x:Class="SmsOpsHQ.Desktop.Views.LateCustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:LateCustomersViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded">

    <Border Padding="28,24" Background="{StaticResource Bg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,14">
                <Button DockPanel.Dock="Right" Command="{Binding LoadCommand}"
                        Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}"
                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="90"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Late Customers" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalCount, StringFormat='({0})'}" FontSize="13"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                </StackPanel>
            </DockPanel>

            <!-- Data grid -->
            <Border Grid.Row="1" CornerRadius="6" BorderBrush="{StaticResource Border}"
                    BorderThickness="1" Background="White">
                <DataGrid ItemsSource="{Binding Customers}" AutoGenerateColumns="False"
                          IsReadOnly="True" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                        <DataGridTextColumn Header="Ticket #" Binding="{Binding TransNo}" Width="80"/>
                        <DataGridTextColumn Header="Due Date" Binding="{Binding DueDate}" Width="100"/>
                        <DataGridTextColumn Header="Days Late" Binding="{Binding DaysLate}" Width="80"/>
                        <DataGridTextColumn Header="Balance" Binding="{Binding Balance, StringFormat='${0:N2}'}" Width="90"/>
                        <DataGridTemplateColumn Header="" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Send Reminder"
                                            Command="{Binding DataContext.SendReminderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource PrimaryButton}"
                                            Padding="10,4" FontSize="11"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Error -->
            <Border Grid.Row="2" Background="{StaticResource ErrorLight}" CornerRadius="5"
                    Padding="14,8" Margin="0,10,0,0"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
