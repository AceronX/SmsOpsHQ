<UserControl x:Class="SmsOpsHQ.Desktop.Views.TemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:TemplatesViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded">

    <Border Padding="28,24" Background="{StaticResource Bg}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Template list -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Button DockPanel.Dock="Right" Command="{Binding NewTemplateCommand}"
                            Style="{StaticResource PrimaryButton}" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="New"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="Message Templates" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                </DockPanel>

                <Border Background="{StaticResource Surface}" CornerRadius="6"
                        BorderBrush="{StaticResource Border}" BorderThickness="1">
                    <ListBox ItemsSource="{Binding Templates}" SelectedItem="{Binding SelectedTemplate}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" BorderBrush="{StaticResource Divider}"
                                        BorderThickness="0,0,0,1" Cursor="Hand">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding Body}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   TextTrimming="CharacterEllipsis" MaxHeight="18"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- Editor panel -->
            <Border Grid.Column="1" Margin="12,0,0,0" Background="{StaticResource Surface}"
                    CornerRadius="8" Padding="20,18"
                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Edit Template" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                    <TextBlock Text="Template Name" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="Message Body" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding EditBody, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             MinHeight="120" Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save" Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="18,8" Margin="0,0,8,0"/>
                        <Button Content="Delete" Command="{Binding DeleteCommand}"
                                Style="{StaticResource DangerButton}"
                                Padding="18,8" Margin="0,0,8,0"
                                Visibility="{Binding EditingTemplateId, Converter={StaticResource NullToCollapsed}}"/>
                        <Button Content="Cancel" Command="{Binding CancelEditCommand}"
                                Padding="18,8"/>
                    </StackPanel>

                    <Border Background="{StaticResource ErrorLight}" CornerRadius="5" Padding="10,7"
                            Margin="0,12,0,0"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
