<UserControl x:Class="SmsOpsHQ.Desktop.Views.InboxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmsOpsHQ.Desktop.ViewModels"
             d:DataContext="{d:DesignInstance vm:InboxViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <!-- Filter pill button -->
        <Style x:Key="FilterPill" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource Bg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header + Search -->
        <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="20,16"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Inbox" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

                <Button DockPanel.Dock="Right" Command="{Binding SearchCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Padding="14,7" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE721;" FontFamily="{StaticResource IconFont}"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Search"/>
                    </StackPanel>
                </Button>

                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         KeyDown="SearchBox_KeyDown"/>
            </DockPanel>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="1" Background="{StaticResource Surface}" Padding="20,8"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding TotalThreads, StringFormat='{}{0} conversations'}"
                           VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource TextMuted}"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="All" Command="{Binding SetFilterCommand}" CommandParameter="all"
                            Style="{StaticResource FilterPill}"/>
                    <Button Content="Open" Command="{Binding SetFilterCommand}" CommandParameter="open"
                            Style="{StaticResource FilterPill}"/>
                    <Button Content="Unread" Command="{Binding SetFilterCommand}" CommandParameter="unread"
                            Style="{StaticResource FilterPill}"/>
                    <Button Content="Closed" Command="{Binding SetFilterCommand}" CommandParameter="closed"
                            Style="{StaticResource FilterPill}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Thread list -->
        <ListBox Grid.Row="2" ItemsSource="{Binding Threads}"
                 SelectedItem="{Binding SelectedThread}"
                 Background="{StaticResource Bg}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="16,12" BorderBrush="{StaticResource Divider}" BorderThickness="0,0,0,1"
                            Background="{StaticResource Surface}" Cursor="Hand">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Avatar circle -->
                            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                    Width="44" Height="44" CornerRadius="22"
                                    Background="{StaticResource Primary}" Margin="0,0,12,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding AvatarLetter}" FontSize="18" FontWeight="SemiBold"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- Row 1: DisplayName + time (bold when unread) -->
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DisplayName}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding LastMessageTime}"
                                       FontSize="11" Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Center"/>

                            <!-- Row 2: Phone + unread badge -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                        Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{Binding CustomerPhone}" FontSize="12"
                                           Foreground="{StaticResource TextSecondary}"/>
                                <Border Visibility="{Binding UnreadCount, Converter={StaticResource CountToVisibility}}"
                                        Background="{StaticResource Primary}" CornerRadius="8"
                                        Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding UnreadCount}" FontSize="10"
                                               Foreground="White" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Loading overlay -->
        <Border Grid.Row="2" Background="#80F4F5F7"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Loading..." FontSize="13"
                           Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Error bar -->
        <Border Grid.Row="3" Background="{StaticResource ErrorLight}" Padding="16,8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Error}" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
