{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=smsops.db"
  },
  "Jwt": {
    "Secret": "SmsOpsHQ-Dev-Secret-Key-Change-In-Production-Min32Chars!",
    "Issuer": "SmsOpsHQ",
    "Audience": "SmsOpsHQ",
    "ExpiresInMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5000",
      "http://localhost:5173",
      "https://localhost:5001"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  }
}
