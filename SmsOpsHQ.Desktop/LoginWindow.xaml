<Window x:Class="SmsOpsHQ.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmsOps HQ - Sign In"
        Height="420" Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid>
        <Border Background="White"
                CornerRadius="8"
                Padding="32,28"
                Margin="24"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="SmsOps HQ"
                           FontSize="24" FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="#1E293B"
                           Margin="0,0,0,4"/>

                <TextBlock Text="Sign in to continue"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Foreground="#94A3B8"
                           Margin="0,0,0,24"/>

                <TextBlock Text="Username"
                           FontSize="13" FontWeight="Medium"
                           Foreground="#334155"
                           Margin="0,0,0,6"/>

                <TextBox x:Name="UsernameBox"
                         FontSize="14"
                         Padding="8,6"
                         Margin="0,0,0,16"/>

                <TextBlock Text="Password"
                           FontSize="13" FontWeight="Medium"
                           Foreground="#334155"
                           Margin="0,0,0,6"/>

                <PasswordBox x:Name="PasswordBox"
                             FontSize="14"
                             Padding="8,6"
                             Margin="0,0,0,8"
                             KeyDown="PasswordBox_KeyDown"/>

                <TextBlock x:Name="ErrorText"
                           Text=""
                           FontSize="12"
                           Foreground="#DC2626"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"
                           Visibility="Collapsed"/>

                <Button x:Name="LoginButton"
                        Content="Sign In"
                        FontSize="14" FontWeight="Medium"
                        Padding="0,10"
                        Margin="0,8,0,0"
                        Background="#1E293B"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="LoginButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
