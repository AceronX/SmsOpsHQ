<Window x:Class="SmsOpsHQ.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmsOps HQ"
        Height="480" Width="720"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar with user info -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <DockPanel>
                <TextBlock Text="SmsOps HQ"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="#1E293B"
                           VerticalAlignment="Center"/>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="UserInfoText"
                               Text=""
                               FontSize="13"
                               Foreground="#64748B"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>

                    <Border x:Name="RoleBadge"
                            Background="#EEF2FF"
                            CornerRadius="4"
                            Padding="8,3"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0">
                        <TextBlock x:Name="RoleText"
                                   Text=""
                                   FontSize="11" FontWeight="Medium"
                                   Foreground="#4338CA"/>
                    </Border>

                    <Button x:Name="LogoutButton"
                            Content="Sign Out"
                            FontSize="12"
                            Padding="12,4"
                            Background="Transparent"
                            Foreground="#64748B"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="LogoutButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content area (placeholder for Phase 2) -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <Border Background="White"
                    CornerRadius="8"
                    Padding="32,24"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="StatusText"
                               Text="Checking API connection..."
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Foreground="#64748B"/>

                    <TextBlock x:Name="ApiUrlText"
                               Text=""
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Foreground="#94A3B8"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Inbox and threads - Phase 2"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Foreground="#CBD5E1"
                       Margin="0,24,0,0"/>
        </StackPanel>
    </Grid>
</Window>
