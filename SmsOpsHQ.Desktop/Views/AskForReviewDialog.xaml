<Window x:Class="SmsOpsHQ.Desktop.Views.AskForReviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ask for Review"
        Width="440" Height="480"
        MinWidth="380" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Bg}"
        Loaded="Dialog_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Border Padding="24,20">
        <StackPanel>
            <TextBlock Text="Ask for Review" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

            <TextBlock Text="Customer Phone Number" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
            <TextBox x:Name="PhoneBox" Padding="10,8" FontSize="13" Margin="0,0,0,16"/>

            <TextBlock Text="Send readiness" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
            <TextBlock x:Name="ReadinessText" FontSize="12" TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,14"/>

            <Button x:Name="SendButton" Content="Send Review Request" Click="SendButton_Click"
                    Style="{StaticResource PrimaryButton}" Padding="16,8" FontSize="13"
                    HorizontalAlignment="Left" Margin="0,0,0,12" IsEnabled="False"/>

            <TextBlock x:Name="StatusText" FontSize="12" TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>

            <Border x:Name="ErrorBorder" Background="{StaticResource ErrorLight}" CornerRadius="5"
                    Padding="10,7" Margin="0,8,0,0" Visibility="Collapsed">
                <TextBlock x:Name="ErrorText" Foreground="{StaticResource Error}" FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
    </Border>
    </ScrollViewer>
</Window>
